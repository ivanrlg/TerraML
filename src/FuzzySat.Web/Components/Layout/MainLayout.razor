@inherits LayoutComponentBase
@inject ProjectPersistenceService Persistence
@inject ProjectLoaderService ProjectLoader
@using FuzzySat.Web.Services

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="top-row-left">
                <span class="breadcrumb-text">FuzzySat</span>
                <span class="breadcrumb-separator">/</span>
                <span class="breadcrumb-current">Dashboard</span>
            </div>
            <div class="top-row-right">
                <span class="fs-badge fs-badge-blue">v0.1.0-alpha</span>
                <a href="https://github.com/ivanrlg/FuzzySat" target="_blank" rel="noopener noreferrer" class="top-link">
                    <span class="material-icons" style="font-size: 1.1rem;">code</span>
                    GitHub
                </a>
            </div>
        </div>

        <article class="content px-4">
            <div class="content-inner fs-fade-in">
                @Body
            </div>
        </article>
    </main>
</div>

<RadzenNotification />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await Persistence.AutoLoadLastProjectAsync(ProjectLoader);
    }
}
