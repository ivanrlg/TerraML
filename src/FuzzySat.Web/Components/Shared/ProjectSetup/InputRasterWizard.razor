@using FuzzySat.Core.Raster
@using FuzzySat.Web.Services
@implements IDisposable
@inject RasterService RasterService
@inject Sentinel2ImportService ImportService
@inject NotificationService NotificationService
@inject ILogger<InputRasterWizard> Logger

<div class="form-section">
    <div class="form-section-header">
        <span class="material-icons section-icon" style="color: var(--fs-accent-cyan);">satellite_alt</span>
        <span>Input Raster</span>
    </div>

    @* Mode toggle *@
    <div class="input-mode-toggle">
        <button type="button" class="mode-btn @(CurrentMode == InputMode.DirectPath ? "mode-active" : "")"
                @onclick="() => SetMode(InputMode.DirectPath)">
            <span class="material-icons" style="font-size: 0.9rem;">description</span>
            Direct Path
        </button>
        <button type="button" class="mode-btn @(CurrentMode == InputMode.ImportSentinel2 ? "mode-active" : "")"
                @onclick="() => SetMode(InputMode.ImportSentinel2)">
            <span class="material-icons" style="font-size: 0.9rem;">cloud_download</span>
            Import Sentinel-2
        </button>
        <button type="button" class="mode-btn @(CurrentMode == InputMode.PreStacked ? "mode-active" : "")"
                @onclick="() => SetMode(InputMode.PreStacked)">
            <span class="material-icons" style="font-size: 0.9rem;">layers</span>
            Pre-stacked
        </button>
    </div>

    @if (CurrentMode == InputMode.DirectPath)
    {
        <div class="field-group">
            <label class="field-label">Path to raster file (.tif, .vrt, .jp2)</label>
            <div class="path-input">
                <RadzenTextBox Value="@InputPath" Change="@OnInputPathChanged" Placeholder="Path to multispectral image" Style="width: 100%;" />
                <button type="button" class="browse-btn" aria-label="Browse for input raster" @onclick="BrowseRaster" title="Browse for input raster">
                    <span class="material-icons">folder_open</span>
                </button>
            </div>
        </div>
    }
    else if (CurrentMode == InputMode.PreStacked)
    {
        @* Pre-stacked multiband raster mode *@
        <div class="field-group">
            <label class="field-label">Path to multiband raster file (.tif, .vrt, .jp2)</label>
            <div class="path-input">
                <RadzenTextBox @bind-Value="@_preStackedPath" Placeholder="Path to pre-stacked multiband image" Style="width: 100%;"
                    Disabled="@_preStackedLoading" />
                <button type="button" class="detect-btn" @onclick="LoadPreStackedRaster" disabled="@_preStackedLoading"
                    title="Load and inspect bands">
                    <span class="material-icons">search</span>
                    <span>Load</span>
                </button>
            </div>
            @if (_preStackedError is not null)
            {
                <p class="field-error">@_preStackedError</p>
            }
        </div>

        @if (_preStackedInfo is not null)
        {
            <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.5rem;">
                <span class="format-badge">@_preStackedInfo.DriverName — @_preStackedInfo.Rows x @_preStackedInfo.Columns</span>
                @if (_preStackedSensor is not null)
                {
                    <span class="format-badge" style="background: var(--fs-accent-emerald); color: white;">@_preStackedSensor detected</span>
                }
            </div>

            @if (_preStackedInfo.Bands.Count > 0)
            {
                <div class="import-band-section">
                    <div class="quick-filters">
                        <button type="button" class="filter-btn @(_preStackedSelectedBands.Count == _preStackedInfo.BandCount ? "filter-btn-active" : "")"
                                @onclick="PreStackedSelectAll">All (@_preStackedInfo.BandCount)</button>
                        <button type="button" class="filter-btn filter-btn-muted" @onclick="PreStackedSelectNone">None</button>
                    </div>

                    <div class="band-grid">
                        @foreach (var band in _preStackedInfo.Bands)
                        {
                            var isSelected = _preStackedSelectedBands.Contains(band.Index);
                            var bandLabel = _preStackedSensorBandNames is not null && band.Index - 1 < _preStackedSensorBandNames.Count
                                ? _preStackedSensorBandNames[band.Index - 1]
                                : $"Band {band.Index}";
                            <button type="button"
                                    class="band-card @(isSelected ? "band-selected" : "")"
                                    aria-pressed="@isSelected"
                                    @onclick="() => TogglePreStackedBand(band.Index)">
                                <div class="band-card-top">
                                    <span class="band-name">@bandLabel</span>
                                    <span class="band-res">@band.DataType</span>
                                </div>
                                <div class="band-card-detail">
                                    <span>#@band.Index</span>
                                    @if (band.ColorInterpretation is not null)
                                    {
                                        <span>@band.ColorInterpretation</span>
                                    }
                                </div>
                            </button>
                        }
                    </div>

                    @if (_preStackedSelectedBands.Count > 0 && _preStackedSelectedBands.Count < _preStackedInfo.BandCount)
                    {
                        <div style="margin-top: 0.5rem;">
                            <RadzenButton Text="@($"Use {_preStackedSelectedBands.Count} Selected Bands")"
                                          Icon="check_circle" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small"
                                          Click="@ApplyPreStackedSubset" IsBusy="@_preStackedBuildingVrt" />
                        </div>
                    }
                    else if (_preStackedSelectedBands.Count == _preStackedInfo.BandCount)
                    {
                        <div class="import-success" style="margin-top: 0.5rem;">
                            <span class="material-icons" style="color: var(--fs-accent-emerald);">check_circle</span>
                            <span>All @_preStackedInfo.BandCount bands selected — using original file</span>
                        </div>
                    }
                </div>
            }

            @* Format conversion hint *@
            @if (_preStackedInfo.DriverName != "GTiff" && _preStackedInfo.DriverName != "VRT")
            {
                <div class="info-banner info-warning" style="margin-top: 0.5rem;">
                    <span class="material-icons">info</span>
                    <span>Format: @_preStackedInfo.DriverName — Consider converting to GeoTIFF for best performance.</span>
                    <RadzenButton Text="Convert to GeoTIFF" Icon="transform" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.ExtraSmall"
                                  Click="@ConvertPreStackedToGeoTiff" IsBusy="@_preStackedConverting" style="margin-left: 0.5rem;" />
                </div>
            }
        }
    }
    else
    {
        @* Import Sentinel-2 inline wizard *@
        <div class="field-group">
            <label class="field-label">Path to folder with Sentinel-2 band files</label>
            <div class="path-input">
                <RadzenTextBox @bind-Value="@_importFolderPath" Placeholder="e.g., C:\Downloads\Barinas_S2" Style="width: 100%;"
                    Disabled="@_isImporting" />
                <button type="button" class="detect-btn" @onclick="DetectSentinel2Source" disabled="@_isImporting"
                    title="Detect format and discover bands">
                    <span class="material-icons">search</span>
                    <span>Detect</span>
                </button>
            </div>
            @if (_importSourceError is not null)
            {
                <p class="field-error">@_importSourceError</p>
            }
        </div>

        @if (_importDetectedFormat is not null)
        {
            <span class="format-badge">@FormatLabel(_importDetectedFormat.Value)</span>
        }

        @if (_discoveredBands.Count > 0)
        {
            @* Band selection *@
            <div class="import-band-section">
                <div class="quick-filters">
                    @foreach (var res in _availableResolutions)
                    {
                        var count = _discoveredBands.Count(b => b.ResolutionMeters == res);
                        var isActiveRes = !HasMixedImportResolutions() && _importSelectedBands.Count > 0
                            && _discoveredBands.Where(b => _importSelectedBands.Contains(b.BandName))
                                .All(b => b.ResolutionMeters == res)
                            && _importSelectedBands.Count == count;
                        <button type="button" class="filter-btn @(isActiveRes ? "filter-btn-active" : "")"
                                @onclick="() => SelectImportByResolution(res)">
                            All @(res)m (@count)
                        </button>
                    }
                    <button type="button" class="filter-btn @(_importSelectedBands.Count == _discoveredBands.Count ? "filter-btn-active" : "")"
                            @onclick="SelectImportAll">All</button>
                    <button type="button" class="filter-btn filter-btn-muted" @onclick="SelectImportNone">None</button>
                </div>

                <div class="band-grid">
                    @foreach (var band in _discoveredBands)
                    {
                        var isSelected = _importSelectedBands.Contains(band.BandName);
                        <button type="button"
                                class="band-card @(isSelected ? "band-selected" : "")"
                                aria-pressed="@isSelected"
                                @onclick="() => ToggleImportBand(band.BandName)">
                            <div class="band-card-top">
                                <span class="band-name">@band.BandName</span>
                                <span class="band-res">@(band.ResolutionMeters)m</span>
                            </div>
                            <div class="band-card-detail">
                                <span>@band.Width x @band.Height</span>
                                <span>@band.DataType</span>
                            </div>
                        </button>
                    }
                </div>

                @if (_importSelectedBands.Count > 0 && HasMixedImportResolutions())
                {
                    <div class="info-banner info-warning">
                        <span class="material-icons">warning</span>
                        <span>Selected bands have different dimensions. Select bands from a single resolution group.</span>
                    </div>
                }

                @* Auto-build status (replaces manual Create VRT button) *@
                @if (_importSelectedBands.Count > 0 && !HasMixedImportResolutions())
                {
                    @if (_isImporting)
                    {
                        <div class="auto-build-status">
                            <RadzenProgressBar Value="@ImportProgressPercent()" ShowValue="false" Style="height: 4px; flex: 1;" />
                            <span class="auto-build-text">
                                Building VRT @(_lastImportProgress is not null ? $"({_lastImportProgress.CurrentBand}/{_lastImportProgress.TotalBands})" : "...")
                            </span>
                        </div>
                    }
                    else if (_importComplete)
                    {
                        <div class="import-success">
                            <span class="material-icons" style="color: var(--fs-accent-emerald);">check_circle</span>
                            <span>VRT ready — @_importSelectedBands.Count bands configured</span>
                        </div>
                    }
                    else if (_buildError is not null)
                    {
                        <div class="info-banner info-warning">
                            <span class="material-icons">error_outline</span>
                            <span>@_buildError</span>
                        </div>
                    }
                    else
                    {
                        @* VRT not yet built — show info that it will auto-build *@
                        <div class="auto-build-status">
                            <span class="material-icons" style="font-size: 0.9rem; color: var(--fs-accent-blue);">info</span>
                            <span class="auto-build-text">VRT will be created automatically in the background</span>
                        </div>
                    }
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public InputMode CurrentMode { get; set; }
    [Parameter] public EventCallback<InputMode> CurrentModeChanged { get; set; }

    [Parameter] public string InputPath { get; set; } = "";
    [Parameter] public EventCallback<string> InputPathChanged { get; set; }

    [Parameter] public string ImportFolderPath { get; set; } = "";
    [Parameter] public EventCallback<string> ImportFolderPathChanged { get; set; }

    [Parameter] public RasterInfo? RasterInfo { get; set; }
    [Parameter] public EventCallback<RasterInfo?> RasterInfoChanged { get; set; }

    [Parameter] public string? RasterError { get; set; }
    [Parameter] public EventCallback<string?> RasterErrorChanged { get; set; }

    /// <summary>Fired when bands are configured (after detect or selection change).</summary>
    [Parameter] public EventCallback<List<BandEntry>> OnBandsImported { get; set; }

    /// <summary>Fired when a sensor is auto-detected (e.g., "Sentinel-2") so parent can set preset.</summary>
    [Parameter] public EventCallback<string> OnSensorDetected { get; set; }

    // --- Internal import state ---
    private string _importFolderPath = "";
    private string _importOutputPath = "";
    private string? _importSourceError;
    private Sentinel2ImportService.InputFormat? _importDetectedFormat;
    private List<Sentinel2ImportService.Sentinel2BandInfo> _discoveredBands = [];
    private HashSet<string> _importSelectedBands = [];
    private IReadOnlyList<int> _availableResolutions = [];
    private bool _isDetecting;
    private bool _isBuildingVrt;
    private bool _isImporting => _isDetecting || _isBuildingVrt;
    private bool _importComplete;
    private CancellationTokenSource? _buildCts;
    private string? _buildError;
    private Sentinel2ImportService.ImportProgress? _lastImportProgress;

    private static readonly Dictionary<string, string> S2BandDescriptions = new(StringComparer.OrdinalIgnoreCase)
    {
        ["B01"] = "Coastal Aerosol", ["B02"] = "Blue", ["B03"] = "Green", ["B04"] = "Red",
        ["B05"] = "Red Edge 1", ["B06"] = "Red Edge 2", ["B07"] = "Red Edge 3",
        ["B08"] = "NIR", ["B8A"] = "NIR Narrow", ["B09"] = "Water Vapour",
        ["B10"] = "Cirrus", ["B11"] = "SWIR 1", ["B12"] = "SWIR 2"
    };

    protected override void OnParametersSet()
    {
        if (_importFolderPath != ImportFolderPath)
            _importFolderPath = ImportFolderPath;
    }

    private async Task SetMode(InputMode mode)
    {
        // Cancel any in-flight VRT build when leaving import mode
        if (mode != InputMode.ImportSentinel2 && _isBuildingVrt)
        {
            _buildCts?.Cancel();
            _buildCts?.Dispose();
            _buildCts = null;
            _isBuildingVrt = false;
        }

        CurrentMode = mode;
        await CurrentModeChanged.InvokeAsync(mode);
    }

    private async Task OnInputPathChanged(string newPath)
    {
        await InputPathChanged.InvokeAsync(newPath);
        await RasterErrorChanged.InvokeAsync(null);
        await RasterInfoChanged.InvokeAsync(null);

        if (string.IsNullOrWhiteSpace(newPath)) return;

        try
        {
            var info = await Task.Run(() => RasterService.GetInfo(newPath));
            await RasterInfoChanged.InvokeAsync(info);
        }
        catch (FileNotFoundException)
        {
            await RasterErrorChanged.InvokeAsync("File not found");
        }
        catch (Exception ex)
        {
            await RasterErrorChanged.InvokeAsync("Cannot read raster");
            Logger.LogWarning(ex, "Failed to read raster info for '{Path}'", newPath);
        }
    }

    private void BrowseRaster()
    {
        NotificationService.Notify(NotificationSeverity.Info, "Coming Soon",
            "File browser requires native file dialog integration. Enter the path manually for now.", duration: 4000);
    }

    // --- Sentinel-2 Import ---

    private async Task DetectSentinel2Source()
    {
        // Cancel any in-flight VRT build from previous detect
        _buildCts?.Cancel();
        _buildCts?.Dispose();
        _buildCts = null;
        _isBuildingVrt = false;

        _importSourceError = null;
        _importDetectedFormat = null;
        _discoveredBands = [];
        _importSelectedBands = [];
        _availableResolutions = [];
        _importComplete = false;
        _buildError = null;
        _lastImportProgress = null;

        if (string.IsNullOrWhiteSpace(_importFolderPath))
        {
            _importSourceError = "Please enter a path.";
            return;
        }

        try
        {
            _isDetecting = true;
            StateHasChanged();

            var format = await Task.Run(() => ImportService.DetectFormat(_importFolderPath));
            _importDetectedFormat = format;

            if (format == Sentinel2ImportService.InputFormat.Unknown)
            {
                _importSourceError = "No supported Sentinel-2 data found at this path.";
                return;
            }
            if (format == Sentinel2ImportService.InputFormat.SafePackage)
            {
                _importSourceError = ".SAFE package support coming soon. Use the extracted band TIFFs from Copernicus Browser.";
                return;
            }
            if (format == Sentinel2ImportService.InputFormat.ZipArchive)
            {
                _importSourceError = "Please extract the .zip file first, then select the extracted folder.";
                return;
            }

            var bands = await Task.Run(() => ImportService.DiscoverBands(_importFolderPath));
            if (bands.Count == 0)
            {
                _importSourceError = "No Sentinel-2 band files found (expected filenames like B02.tif, B04_10m.tif, etc.)";
                return;
            }

            _discoveredBands = bands;
            _availableResolutions = Sentinel2ImportService.GetAvailableResolutions(bands);

            // Auto-select: all bands if same dimensions, otherwise finest resolution
            var allSameDimensions = bands.Count > 0
                && bands.All(b => b.Width == bands[0].Width && b.Height == bands[0].Height);
            if (allSameDimensions)
            {
                _importSelectedBands = bands.Select(b => b.BandName)
                    .ToHashSet(StringComparer.OrdinalIgnoreCase);
            }
            else
            {
                var finest = _availableResolutions.FirstOrDefault();
                if (finest > 0)
                {
                    _importSelectedBands = bands
                        .Where(b => b.ResolutionMeters == finest)
                        .Select(b => b.BandName)
                        .ToHashSet(StringComparer.OrdinalIgnoreCase);
                }
            }

            _importOutputPath = Path.Combine(Path.GetFullPath(_importFolderPath), "sentinel2_stack.vrt");

            // Sync folder path back to parent
            await ImportFolderPathChanged.InvokeAsync(_importFolderPath);

            // AUTO-DETECT: Set preset to Sentinel-2 automatically
            await OnSensorDetected.InvokeAsync("Sentinel-2");

            // AUTO-SYNC: Immediately configure bands from selected cards
            await SyncBandsFromSelection();

            // AUTO-BUILD: Start VRT creation in background
            _ = AutoBuildVrt();
        }
        catch (ArgumentException ex)
        {
            _importSourceError = ex.Message;
        }
        catch (Exception ex)
        {
            _importSourceError = "Failed to read source directory.";
            Logger.LogWarning(ex, "Failed to detect Sentinel-2 source at '{Path}'", _importFolderPath);
        }
        finally
        {
            _isDetecting = false;
        }
    }

    /// <summary>Sync band configuration from current card selection to parent (immediate, no VRT needed).</summary>
    private async Task SyncBandsFromSelection()
    {
        var selectedBandInfos = _discoveredBands
            .Where(b => _importSelectedBands.Contains(b.BandName))
            .ToList();

        if (selectedBandInfos.Count == 0) return;

        var importedBands = selectedBandInfos.Select((b, i) => new BandEntry(
            b.BandName,
            i,
            S2BandDescriptions.GetValueOrDefault(b.BandName, "")
        )).ToList();

        await OnBandsImported.InvokeAsync(importedBands);
    }

    /// <summary>Auto-build VRT in background after detection or band selection change.</summary>
    private async Task AutoBuildVrt()
    {
        if (string.IsNullOrWhiteSpace(_importOutputPath)) return;
        if (HasMixedImportResolutions()) return;

        var selectedBandInfos = _discoveredBands
            .Where(b => _importSelectedBands.Contains(b.BandName))
            .ToList();
        if (selectedBandInfos.Count == 0) return;

        // Cancel any in-flight build before starting a new one
        _buildCts?.Cancel();
        _buildCts?.Dispose();
        _buildCts = new CancellationTokenSource();
        var ct = _buildCts.Token;

        _isBuildingVrt = true;
        _importComplete = false;
        _lastImportProgress = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            _buildError = null;
            var options = new Sentinel2ImportService.ImportOptions(selectedBandInfos, _importOutputPath);
            var progress = new Progress<Sentinel2ImportService.ImportProgress>(p =>
            {
                _lastImportProgress = p;
                InvokeAsync(StateHasChanged);
            });

            var result = await ImportService.BuildVrtAsync(options, progress, ct);
            _importOutputPath = result;
            _importComplete = true;

            // Set input path to the VRT and clear any previous raster error
            await RasterErrorChanged.InvokeAsync(null);
            await InputPathChanged.InvokeAsync(result);
            try
            {
                var info = await Task.Run(() => RasterService.GetInfo(result));
                await RasterInfoChanged.InvokeAsync(info);
            }
            catch { /* raster info is optional here */ }

            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
            // Superseded by a newer build — no action needed
            return;
        }
        catch (Exception ex)
        {
            _buildError = "VRT build failed. Re-detect or change band selection to retry.";
            Logger.LogWarning(ex, "Auto-build VRT failed");
        }
        finally
        {
            // Only clear the flag if this build is still the current one
            // (a newer build may have already set _isBuildingVrt = true)
            if (_buildCts?.Token == ct || _buildCts is null)
                _isBuildingVrt = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ToggleImportBand(string bandName)
    {
        if (!_importSelectedBands.Remove(bandName))
            _importSelectedBands.Add(bandName);
        _importComplete = false;
        await OnBandSelectionChanged();
    }

    private async Task SelectImportByResolution(int resolution)
    {
        _importSelectedBands = _discoveredBands
            .Where(b => b.ResolutionMeters == resolution)
            .Select(b => b.BandName)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        _importComplete = false;
        await OnBandSelectionChanged();
    }

    private async Task SelectImportAll()
    {
        _importSelectedBands = _discoveredBands.Select(b => b.BandName).ToHashSet(StringComparer.OrdinalIgnoreCase);
        _importComplete = false;
        await OnBandSelectionChanged();
    }

    private void SelectImportNone()
    {
        _importSelectedBands.Clear();
        _importComplete = false;
        // Cancel any in-progress build since no bands are selected
        _buildCts?.Cancel();
        _buildCts?.Dispose();
        _buildCts = null;
        _isBuildingVrt = false;
        _lastImportProgress = null;
        _buildError = null;
    }

    /// <summary>Called after any band selection change — syncs bands to parent and rebuilds VRT.</summary>
    private async Task OnBandSelectionChanged()
    {
        if (_importSelectedBands.Count == 0 || HasMixedImportResolutions()) return;

        // Update VRT output path for new selection
        _importOutputPath = Path.Combine(Path.GetFullPath(_importFolderPath), "sentinel2_stack.vrt");

        // Immediately sync bands to parent
        await SyncBandsFromSelection();

        // Rebuild VRT in background
        _ = AutoBuildVrt();
    }

    private bool HasMixedImportResolutions()
    {
        var selected = _discoveredBands.Where(b => _importSelectedBands.Contains(b.BandName)).ToList();
        if (selected.Count <= 1) return false;
        var first = (selected[0].Width, selected[0].Height);
        return selected.Any(b => b.Width != first.Width || b.Height != first.Height);
    }

    private double ImportProgressPercent() =>
        _lastImportProgress is null || _lastImportProgress.TotalBands == 0
            ? 0
            : (double)_lastImportProgress.CurrentBand / _lastImportProgress.TotalBands * 100;

    private static string FormatLabel(Sentinel2ImportService.InputFormat format) => format switch
    {
        Sentinel2ImportService.InputFormat.BandFolder => "Band Folder",
        Sentinel2ImportService.InputFormat.SafePackage => ".SAFE Package",
        Sentinel2ImportService.InputFormat.ZipArchive => "ZIP Archive",
        _ => "Unknown"
    };

    // --- Pre-stacked mode state ---
    private string _preStackedPath = "";
    private string? _preStackedError;
    private RasterInfo? _preStackedInfo;
    private string? _preStackedSensor;
    private IReadOnlyList<string>? _preStackedSensorBandNames;
    private HashSet<int> _preStackedSelectedBands = [];
    private bool _preStackedLoading;
    private bool _preStackedBuildingVrt;
    private bool _preStackedConverting;

    private async Task LoadPreStackedRaster()
    {
        _preStackedError = null;
        _preStackedInfo = null;
        _preStackedSensor = null;
        _preStackedSensorBandNames = null;
        _preStackedSelectedBands = [];

        if (string.IsNullOrWhiteSpace(_preStackedPath))
        {
            _preStackedError = "Please enter a path.";
            return;
        }

        try
        {
            _preStackedLoading = true;
            StateHasChanged();

            var info = await Task.Run(() => RasterService.GetInfo(_preStackedPath));
            _preStackedInfo = info;

            // Auto-detect sensor
            _preStackedSensor = SensorDetector.DetectFromBandCount(info.BandCount);
            if (_preStackedSensor is not null)
            {
                _preStackedSensorBandNames = SensorDetector.GetBandNames(_preStackedSensor);
                await OnSensorDetected.InvokeAsync(_preStackedSensor);
            }

            // Select all bands by default
            _preStackedSelectedBands = Enumerable.Range(1, info.BandCount).ToHashSet();

            // Set input path and raster info
            await InputPathChanged.InvokeAsync(_preStackedPath);
            await RasterInfoChanged.InvokeAsync(info);
            await RasterErrorChanged.InvokeAsync(null);

            // Sync band configuration
            await SyncPreStackedBands();
        }
        catch (FileNotFoundException)
        {
            _preStackedError = "File not found.";
            await RasterInfoChanged.InvokeAsync(null);
            await RasterErrorChanged.InvokeAsync("File not found");
        }
        catch (Exception ex)
        {
            _preStackedError = "Cannot read raster file.";
            await RasterInfoChanged.InvokeAsync(null);
            await RasterErrorChanged.InvokeAsync("Cannot read raster file");
            Logger.LogWarning(ex, "Failed to load pre-stacked raster at '{Path}'", _preStackedPath);
        }
        finally
        {
            _preStackedLoading = false;
        }
    }

    private void TogglePreStackedBand(int index)
    {
        if (!_preStackedSelectedBands.Remove(index))
            _preStackedSelectedBands.Add(index);
    }

    private void PreStackedSelectAll()
    {
        if (_preStackedInfo is null) return;
        _preStackedSelectedBands = Enumerable.Range(1, _preStackedInfo.BandCount).ToHashSet();
    }

    private void PreStackedSelectNone()
    {
        _preStackedSelectedBands.Clear();
    }

    private async Task SyncPreStackedBands()
    {
        if (_preStackedInfo is null) return;
        var bands = _preStackedSelectedBands.Order().Select((idx, i) =>
        {
            var name = _preStackedSensorBandNames is not null && idx - 1 < _preStackedSensorBandNames.Count
                ? _preStackedSensorBandNames[idx - 1]
                : $"Band{idx}";
            return new BandEntry(name, i, _preStackedInfo.Bands.FirstOrDefault(b => b.Index == idx)?.Description ?? "");
        }).ToList();
        await OnBandsImported.InvokeAsync(bands);
    }

    private async Task ApplyPreStackedSubset()
    {
        if (_preStackedInfo is null || _preStackedSelectedBands.Count == 0) return;

        try
        {
            _preStackedBuildingVrt = true;
            StateHasChanged();

            var indices = _preStackedSelectedBands.Order().ToList();
            var vrtPath = Path.ChangeExtension(_preStackedPath, null) + "_subset.vrt";

            await Task.Run(() => GdalRasterUtils.CreateBandSubsetVrt(_preStackedPath, indices, vrtPath));

            await InputPathChanged.InvokeAsync(vrtPath);
            var info = await Task.Run(() => RasterService.GetInfo(vrtPath));
            await RasterInfoChanged.InvokeAsync(info);

            // Update local state to reflect the active VRT
            _preStackedPath = vrtPath;
            _preStackedInfo = info;
            _preStackedSelectedBands = Enumerable.Range(1, indices.Count).ToHashSet();
            await SyncPreStackedBands();

            NotificationService.Notify(NotificationSeverity.Success, "Subset Created",
                $"VRT with {indices.Count} bands created.", duration: 3000);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Subset Failed", ex.Message, duration: 5000);
            Logger.LogWarning(ex, "Failed to create band subset VRT");
        }
        finally
        {
            _preStackedBuildingVrt = false;
        }
    }

    private async Task ConvertPreStackedToGeoTiff()
    {
        if (_preStackedInfo is null) return;

        try
        {
            _preStackedConverting = true;
            StateHasChanged();

            var ext = Path.GetExtension(_preStackedPath);
            var outputPath = string.Equals(ext, ".tif", StringComparison.OrdinalIgnoreCase)
                || string.Equals(ext, ".tiff", StringComparison.OrdinalIgnoreCase)
                ? Path.ChangeExtension(_preStackedPath, null) + "_converted.tif"
                : Path.ChangeExtension(_preStackedPath, ".tif");
            await Task.Run(() => GdalRasterUtils.TranslateFormat(_preStackedPath, outputPath));

            _preStackedPath = outputPath;
            await InputPathChanged.InvokeAsync(outputPath);
            var info = await Task.Run(() => RasterService.GetInfo(outputPath));
            _preStackedInfo = info;
            await RasterInfoChanged.InvokeAsync(info);

            NotificationService.Notify(NotificationSeverity.Success, "Conversion Complete",
                $"Converted to GeoTIFF: {Path.GetFileName(outputPath)}", duration: 3000);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Conversion Failed", ex.Message, duration: 5000);
            Logger.LogWarning(ex, "Failed to convert raster to GeoTIFF");
        }
        finally
        {
            _preStackedConverting = false;
        }
    }

    /// <summary>Reset internal import state (called by parent on Reset).</summary>
    public void Reset()
    {
        _buildCts?.Cancel();
        _buildCts?.Dispose();
        _buildCts = null;
        _isDetecting = false;
        _isBuildingVrt = false;
        _importFolderPath = "";
        _importOutputPath = "";
        _importSourceError = null;
        _importDetectedFormat = null;
        _discoveredBands = [];
        _importSelectedBands = [];
        _availableResolutions = [];
        _importComplete = false;
        _lastImportProgress = null;
        _buildError = null;
        // Pre-stacked state
        _preStackedPath = "";
        _preStackedError = null;
        _preStackedInfo = null;
        _preStackedSensor = null;
        _preStackedSensorBandNames = null;
        _preStackedSelectedBands = [];
        _preStackedLoading = false;
        _preStackedBuildingVrt = false;
        _preStackedConverting = false;
    }

    public void Dispose()
    {
        _buildCts?.Cancel();
        _buildCts?.Dispose();
        _buildCts = null;
    }
}
