@page "/training"
@rendermode InteractiveServer
@inject NotificationService NotificationService

<PageTitle>Training - FuzzySat</PageTitle>

<div class="training-page fs-fade-in">
    <div class="page-header">
        <div>
            <h1 class="page-title">Training Editor</h1>
            <p class="page-subtitle">Draw training areas on the map and extract spectral statistics for each land cover class.</p>
        </div>
        <span class="fs-badge fs-badge-emerald">Step 3 of 5</span>
    </div>

    @* Mock Drawing Toolbar *@
    <div class="drawing-toolbar">
        <div class="toolbar-group">
            <button type="button" class="tool-btn" title="Draw Polygon" aria-label="Draw Polygon" disabled>
                <span class="material-icons" aria-hidden="true">pentagon</span>
            </button>
            <button type="button" class="tool-btn" title="Draw Rectangle" aria-label="Draw Rectangle" disabled>
                <span class="material-icons" aria-hidden="true">crop_landscape</span>
            </button>
            <button type="button" class="tool-btn" title="Point Sample" aria-label="Point Sample" disabled>
                <span class="material-icons" aria-hidden="true">location_on</span>
            </button>
        </div>
        <div class="toolbar-divider"></div>
        <div class="toolbar-group">
            <button type="button" class="tool-btn" title="Edit" aria-label="Edit" disabled>
                <span class="material-icons" aria-hidden="true">edit</span>
            </button>
            <button type="button" class="tool-btn" title="Delete" aria-label="Delete" disabled>
                <span class="material-icons" aria-hidden="true">delete_outline</span>
            </button>
        </div>
        <div class="toolbar-spacer"></div>
        <span class="toolbar-hint">Load a project to enable drawing tools</span>
    </div>

    <div class="main-layout">
        @* Map Area *@
        <div class="map-col">
            <MapPlaceholder Height="480px" Message="Load a project to draw training areas" Icon="draw" />
        </div>

        @* Right Panel *@
        <div class="panel-col">
            @* Class Cards *@
            <div class="panel-section">
                <div class="panel-header">
                    <span class="material-icons" style="font-size: 1rem; color: var(--fs-accent-blue);">palette</span>
                    <span>Training Classes</span>
                </div>
                @foreach (var cls in _classes)
                {
                    var isSelected = _selectedClass == cls.Name;
                    <button type="button" class="class-card @(isSelected ? "class-selected" : "")" @onclick="() => _selectedClass = cls.Name">
                        <span class="class-dot" style="background: @cls.Color;"></span>
                        <span class="class-name">@cls.Name</span>
                        <span class="class-samples mono-text">@cls.Samples pts</span>
                    </button>
                }
            </div>

            @* Spectral Signature Chart *@
            <div class="panel-section">
                <div class="panel-header">
                    <span class="material-icons" style="font-size: 1rem; color: var(--fs-accent-cyan);">show_chart</span>
                    <span>Spectral Signatures</span>
                </div>
                <RadzenChart Style="height: 200px;">
                    @foreach (var cls in _classes)
                    {
                        <RadzenLineSeries Data="@cls.SpectralData" CategoryProperty="Band" ValueProperty="Value"
                                          Title="@cls.Name" Stroke="@cls.Color" StrokeWidth="2">
                            <RadzenMarkers MarkerType="MarkerType.Circle" Size="4" Stroke="@cls.Color" Fill="@cls.Color" />
                        </RadzenLineSeries>
                    }
                    <RadzenCategoryAxis />
                    <RadzenValueAxis>
                        <RadzenGridLines Visible="true" />
                    </RadzenValueAxis>
                    <RadzenLegend Visible="false" />
                </RadzenChart>
            </div>

            @* Actions *@
            <div class="panel-actions">
                <RadzenButton Text="Extract Statistics" Icon="calculate" ButtonStyle="ButtonStyle.Primary" Style="width: 100%;" Click="@ExtractStatistics" />
                <RadzenButton Text="Export Session" Icon="file_download" ButtonStyle="ButtonStyle.Secondary" Style="width: 100%;" Click="@ExportSession" />
            </div>
        </div>
    </div>
</div>

@code {
    private string? _selectedClass = "Urban";

    private List<TrainingClass> _classes =
    [
        new("Urban", "#EF4444", 24, [new("VNIR1", 128), new("VNIR2", 95), new("SWIR1", 72), new("SWIR2", 88)]),
        new("Water", "#3B82F6", 23, [new("VNIR1", 35), new("VNIR2", 28), new("SWIR1", 15), new("SWIR2", 12)]),
        new("Forest", "#10B981", 25, [new("VNIR1", 55), new("VNIR2", 180), new("SWIR1", 45), new("SWIR2", 38)]),
        new("Agriculture", "#F59E0B", 23, [new("VNIR1", 68), new("VNIR2", 145), new("SWIR1", 55), new("SWIR2", 48)]),
        new("Bare Soil", "#D97706", 22, [new("VNIR1", 115), new("VNIR2", 100), new("SWIR1", 95), new("SWIR2", 105)])
    ];

    private void ExtractStatistics()
    {
        NotificationService.Notify(NotificationSeverity.Info, "Coming Soon",
            "Statistics extraction requires training areas drawn on a loaded raster.", duration: 4000);
    }

    private void ExportSession()
    {
        NotificationService.Notify(NotificationSeverity.Info, "Coming Soon",
            "Training session export will be available after extracting statistics.", duration: 4000);
    }

    private record SpectralPoint(string Band, double Value);
    private record TrainingClass(string Name, string Color, int Samples, List<SpectralPoint> SpectralData);
}
