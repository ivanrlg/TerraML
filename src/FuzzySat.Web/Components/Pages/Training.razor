@page "/training"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject NotificationService NotificationService
@inject ProjectStateService ProjectState
@inject TrainingService TrainingService
@inject RasterService RasterService
@inject PixelExtractionService PixelExtractor
@inject IJSRuntime JSRuntime

<PageTitle>Training - FuzzySat</PageTitle>

<div class="training-page fs-fade-in">
    <div class="page-header">
        <div>
            <h1 class="page-title">Training Editor</h1>
            <p class="page-subtitle">Select training areas on the image or import samples from CSV.</p>
        </div>
        <span class="fs-badge fs-badge-emerald">Step 3 of 5</span>
    </div>

    @if (!ProjectState.HasProject)
    {
        <div class="fs-card" style="text-align: center; padding: 3rem;">
            <span class="material-icons" style="font-size: 3rem; color: var(--fs-text-tertiary); margin-bottom: 1rem;">school</span>
            <h3 style="color: var(--fs-text-secondary);">No Project Loaded</h3>
            <p style="color: var(--fs-text-tertiary);">Configure a project in <a href="/project-setup" style="color: var(--fs-accent-blue);">Project Setup</a> first.</p>
        </div>
    }
    else
    {
        @* Toolbar *@
        <div class="drawing-toolbar">
            <div class="toolbar-group">
                @if (_hasRaster)
                {
                    <button type="button" class="tool-btn @(_mode == "draw" ? "tool-btn-active" : "")"
                            title="Draw rectangle to select training area"
                            @onclick="SwitchToDrawMode">
                        <span class="material-icons" aria-hidden="true">crop_landscape</span>
                    </button>
                }
                <label class="tool-btn @(_mode == "csv" ? "tool-btn-active" : "")" title="Import training samples from CSV" style="cursor: pointer;"
                       @onclick='() => _mode = "csv"'>
                    <span class="material-icons" aria-hidden="true">upload_file</span>
                    <InputFile OnChange="@OnCsvUploaded" accept=".csv" style="display: none;" />
                </label>
            </div>
            @if (_hasRaster && _mode == "draw")
            {
                <div class="toolbar-divider"></div>
                <div class="toolbar-group">
                    <span style="color: var(--fs-text-tertiary); font-size: 0.8rem; margin-right: 0.5rem;">View:</span>
                    <RadzenDropDown @bind-Value="@_viewMode" Data="@_viewModes"
                                    Style="width: 120px; height: 32px;" Change="@(_ => OnViewModeChanged())" />
                </div>
                @if (_viewMode == "Single")
                {
                    <div class="toolbar-group">
                        <span style="color: var(--fs-text-tertiary); font-size: 0.8rem; margin-right: 0.5rem;">Band:</span>
                        <RadzenDropDown @bind-Value="@_selectedBandIndex" Data="@_bandOptions"
                                        TextProperty="Name" ValueProperty="Index"
                                        Style="width: 120px; height: 32px;" Change="@(_ => OnBandChanged())" />
                    </div>
                }
                else
                {
                    <div class="toolbar-group">
                        <span style="color: #EF4444; font-size: 0.8rem; margin-right: 0.25rem;">R</span>
                        <RadzenDropDown @bind-Value="@_redBandIndex" Data="@_bandOptions"
                                        TextProperty="Name" ValueProperty="Index"
                                        Style="width: 100px; height: 32px;" Change="@(_ => OnBandChanged())" />
                    </div>
                    <div class="toolbar-group">
                        <span style="color: #10B981; font-size: 0.8rem; margin-right: 0.25rem;">G</span>
                        <RadzenDropDown @bind-Value="@_greenBandIndex" Data="@_bandOptions"
                                        TextProperty="Name" ValueProperty="Index"
                                        Style="width: 100px; height: 32px;" Change="@(_ => OnBandChanged())" />
                    </div>
                    <div class="toolbar-group">
                        <span style="color: #3B82F6; font-size: 0.8rem; margin-right: 0.25rem;">B</span>
                        <RadzenDropDown @bind-Value="@_blueBandIndex" Data="@_bandOptions"
                                        TextProperty="Name" ValueProperty="Index"
                                        Style="width: 100px; height: 32px;" Change="@(_ => OnBandChanged())" />
                    </div>
                }
                <div class="toolbar-divider"></div>
                <div class="toolbar-group">
                    <span style="color: var(--fs-text-tertiary); font-size: 0.8rem; margin-right: 0.5rem;">Class:</span>
                    <RadzenDropDown @bind-Value="@_selectedClass" Data="@_classOptions"
                                    TextProperty="Name" ValueProperty="Name"
                                    Style="width: 120px; height: 32px;" Change="@(_ => OnClassChanged())" />
                </div>
            }
            <div class="toolbar-spacer"></div>
            @if (_samples.Count > 0)
            {
                <span class="fs-badge fs-badge-emerald mono-text">@_samples.Count samples</span>
            }
            @if (_regions.Count > 0)
            {
                <button type="button" class="tool-btn" title="Clear all regions" @onclick="ClearAllRegions">
                    <span class="material-icons" aria-hidden="true">delete_sweep</span>
                </button>
            }
        </div>

        <div class="main-layout">
            @* Image Area *@
            <div class="map-col">
                @if (_hasRaster && _mode == "draw")
                {
                    <div class="band-preview-container" style="position: relative; display: inline-block;">
                        @if (!string.IsNullOrEmpty(_bandPreviewBase64))
                        {
                            <img id="training-preview-img" src="data:image/png;base64,@_bandPreviewBase64"
                                 alt="Band preview" style="display: block; max-width: 100%; max-height: 520px;" />
                            <canvas id="training-selection-canvas"
                                    style="position: absolute; top: 0; left: 0; cursor: crosshair; width: 100%; height: 100%;"></canvas>
                        }
                        else if (_isLoadingPreview)
                        {
                            <div style="display: flex; align-items: center; justify-content: center; height: 400px; color: var(--fs-text-tertiary);">
                                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
                                <span style="margin-left: 0.5rem;">Loading preview...</span>
                            </div>
                        }
                        else
                        {
                            <div style="display: flex; align-items: center; justify-content: center; height: 400px; color: var(--fs-text-tertiary);">
                                <span class="material-icons" style="font-size: 2rem; margin-right: 0.5rem;">hourglass_empty</span>
                                Loading band preview...
                            </div>
                        }
                    </div>
                    @if (_regions.Count > 0)
                    {
                        <div style="margin-top: 0.75rem;">
                            <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
                                @for (var i = 0; i < _regions.Count; i++)
                                {
                                    var idx = i;
                                    var r = _regions[i];
                                    <div style="display: flex; align-items: center; gap: 0.4rem; padding: 0.3rem 0.6rem; background: var(--fs-bg-tertiary); border-radius: 6px; border: 1px solid @(r.Color)33;">
                                        <span style="width: 8px; height: 8px; border-radius: 50%; background: @r.Color; flex-shrink: 0;"></span>
                                        <span style="color: var(--fs-text-secondary); font-size: 0.8rem;">@r.ClassName</span>
                                        <span class="mono-text" style="color: var(--fs-text-tertiary); font-size: 0.75rem;">@r.PixelCount px</span>
                                        <button type="button" style="background: none; border: none; cursor: pointer; color: var(--fs-text-tertiary); padding: 0; line-height: 1;"
                                                title="Remove region" @onclick="() => RemoveRegion(idx)">
                                            <span class="material-icons" style="font-size: 0.9rem;">close</span>
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else if (_mode == "csv" || !_hasRaster)
                {
                    <MapPlaceholder Height="480px"
                                    Message="@(_hasRaster ? "Switch to Draw mode or upload a CSV file." : "Set an Input Raster in Project Setup to enable drawing. Use CSV import instead.")"
                                    Icon="@(_hasRaster ? "upload_file" : "image")" />
                }
            </div>

            @* Right Panel *@
            <div class="panel-col">
                @* Class Cards *@
                <div class="panel-section">
                    <div class="panel-header">
                        <span class="material-icons" style="font-size: 1rem; color: var(--fs-accent-blue);">palette</span>
                        <span>Training Classes</span>
                    </div>
                    @foreach (var cls in _classCards)
                    {
                        var isSelected = _selectedClass == cls.Name;
                        <button type="button" class="class-card @(isSelected ? "class-selected" : "")" @onclick="() => SelectClass(cls.Name)">
                            <span class="class-dot" style="background: @cls.Color;"></span>
                            <span class="class-name">@cls.Name</span>
                            <span class="class-samples mono-text">@cls.Samples pts</span>
                        </button>
                    }
                </div>

                @* Spectral Signature Chart *@
                @if (_spectralSeries.Count > 0)
                {
                    <div class="panel-section">
                        <div class="panel-header">
                            <span class="material-icons" style="font-size: 1rem; color: var(--fs-accent-cyan);">show_chart</span>
                            <span>Spectral Signatures (Mean)</span>
                        </div>
                        <RadzenChart Style="height: 200px;">
                            @foreach (var series in _spectralSeries)
                            {
                                <RadzenLineSeries Data="@series.Points" CategoryProperty="Band" ValueProperty="Value"
                                                  Title="@series.Name" Stroke="@series.Color" StrokeWidth="2">
                                    <RadzenMarkers MarkerType="MarkerType.Circle" Size="4" Stroke="@series.Color" Fill="@series.Color" />
                                </RadzenLineSeries>
                            }
                            <RadzenCategoryAxis />
                            <RadzenValueAxis>
                                <RadzenGridLines Visible="true" />
                            </RadzenValueAxis>
                            <RadzenLegend Visible="false" />
                        </RadzenChart>
                    </div>
                }

                @* Info Banner *@
                @if (_hasRaster && _mode == "draw" && _bandNames.Count > 0)
                {
                    <div style="padding: 0.5rem 0.75rem; background: rgba(6, 182, 212, 0.08); border: 1px solid rgba(6, 182, 212, 0.2); border-radius: 8px; margin-bottom: 0.75rem;">
                        <div style="display: flex; align-items: center; gap: 0.4rem;">
                            <span class="material-icons" style="font-size: 0.9rem; color: var(--fs-accent-cyan);">info</span>
                            <span style="color: var(--fs-accent-cyan); font-size: 0.8rem;">
                                Each rectangle extracts pixel values from <strong>all @_bandNames.Count bands</strong>.
                            </span>
                        </div>
                    </div>
                }

                @* Actions *@
                <div class="panel-actions">
                    <RadzenButton Text="Extract & Train" Icon="calculate" ButtonStyle="ButtonStyle.Primary"
                                  Style="width: 100%;" Click="@ExtractStatistics"
                                  Disabled="@(_samples.Count == 0 || _isProcessing)" />
                    <RadzenButton Text="Export CSV" Icon="table_chart" ButtonStyle="ButtonStyle.Secondary"
                                  Style="width: 100%;" Click="@ExportCsv"
                                  Disabled="@(_samples.Count == 0)" />
                    <RadzenButton Text="Export Session" Icon="file_download" ButtonStyle="ButtonStyle.Secondary"
                                  Style="width: 100%;" Click="@ExportSession"
                                  Disabled="@(!ProjectState.HasTrainingSession)" />
                </div>
            </div>
        </div>
    }
</div>

@code {
    private string _mode = "draw"; // "draw" or "csv"
    private string _viewMode = "Single"; // "Single" or "RGB" — default Single, switch to RGB after bands loaded
    private string? _selectedClass;
    private bool _isProcessing = false;
    private bool _isLoadingPreview = false;
    private bool _hasRaster = false;
    private bool _canvasInitialized = false;
    private bool _needsCanvasInit = false;
    private List<LabeledPixelSample> _samples = [];
    private List<string> _bandNames = [];
    private List<ClassCard> _classCards = [];
    private List<SpectralSeries> _spectralSeries = [];
    private List<TrainingRegion> _regions = [];

    // Band preview
    private int _selectedBandIndex = 0;
    private int _redBandIndex = 2;   // Default: Red band (index 2 for S2 = B04/Red)
    private int _greenBandIndex = 1; // Default: Green band (index 1 for S2 = B03/Green)
    private int _blueBandIndex = 0;  // Default: Blue band (index 0 for S2 = B02/Blue)
    private string? _bandPreviewBase64;
    private Core.Raster.MultispectralImage? _image;
    private List<BandOption> _bandOptions = [];
    private List<ClassOption> _classOptions = [];
    private List<string> _viewModes = ["Single", "RGB"];

    private DotNetObjectReference<Training>? _dotNetRef;

    public async ValueTask DisposeAsync()
    {
        if (_dotNetRef is not null)
        {
            try { await JSRuntime.InvokeVoidAsync("trainingSelection.dispose"); }
            catch (Microsoft.JSInterop.JSDisconnectedException) { }
            _dotNetRef.Dispose();
            _dotNetRef = null;
        }
    }

    protected override void OnInitialized()
    {
        if (ProjectState.HasProject && ProjectState.Configuration?.Classes is not null)
        {
            _classOptions = ProjectState.Configuration.Classes
                .Select(c => new ClassOption(c.Name, c.Color ?? "#808080"))
                .ToList();
            _classCards = _classOptions
                .Select(c => new ClassCard(c.Name, c.Color, 0))
                .ToList();
            _selectedClass = _classCards.FirstOrDefault()?.Name;

            _hasRaster = !string.IsNullOrWhiteSpace(ProjectState.Configuration.InputRasterPath);
            if (!_hasRaster) _mode = "csv";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _hasRaster && _mode == "draw")
        {
            await LoadBandPreview();
        }

        // Deferred canvas init after DOM update
        if (_needsCanvasInit && !string.IsNullOrEmpty(_bandPreviewBase64))
        {
            _needsCanvasInit = false;
            await InitCanvas();
            await RehydrateRegionsOnCanvas();
        }
    }

    private async Task LoadBandPreview()
    {
        if (!_hasRaster || ProjectState.Configuration?.InputRasterPath is null) return;

        _isLoadingPreview = true;
        StateHasChanged();

        try
        {
            var path = ProjectState.Configuration.InputRasterPath;
            var bandIdx = _selectedBandIndex;
            var rIdx = _redBandIndex;
            var gIdx = _greenBandIndex;
            var bIdx = _blueBandIndex;
            var isRgb = _viewMode == "RGB";

            // All heavy work on background thread
            var (img, bandOpts, preview, bands) = await Task.Run(() =>
            {
                var image = _image ?? RasterService.ReadImage(path);
                var opts = image.BandNames.Select((n, i) => new BandOption(n, i)).ToList();
                byte[] png;

                if (isRgb && image.BandNames.Count >= 3)
                {
                    var ri = Math.Clamp(rIdx, 0, image.BandNames.Count - 1);
                    var gi = Math.Clamp(gIdx, 0, image.BandNames.Count - 1);
                    var bi = Math.Clamp(bIdx, 0, image.BandNames.Count - 1);
                    var rBand = image.GetBand(image.BandNames[ri]);
                    var gBand = image.GetBand(image.BandNames[gi]);
                    var bBand = image.GetBand(image.BandNames[bi]);
                    var rStats = RasterService.ComputeBandStatistics(rBand);
                    var gStats = RasterService.ComputeBandStatistics(gBand);
                    var bStats = RasterService.ComputeBandStatistics(bBand);
                    png = RasterService.RenderRgbComposite(rBand, gBand, bBand, rStats, gStats, bStats);
                }
                else
                {
                    var idx = Math.Clamp(bandIdx, 0, image.BandNames.Count - 1);
                    var band = image.GetBand(image.BandNames[idx]);
                    var stats = RasterService.ComputeBandStatistics(band);
                    png = RasterService.RenderBandPreview(band, stats);
                }

                return (image, opts, Convert.ToBase64String(png), image.BandNames.ToList());
            });

            _image = img;
            _bandOptions = bandOpts;
            _bandPreviewBase64 = preview;
            _bandNames = bands;

            // Clamp RGB indices and force Single mode if < 3 bands
            if (_bandOptions.Count < 3)
            {
                _viewMode = "Single";
            }
            if (_bandOptions.Count > 0)
            {
                _redBandIndex = Math.Clamp(_redBandIndex, 0, _bandOptions.Count - 1);
                _greenBandIndex = Math.Clamp(_greenBandIndex, 0, _bandOptions.Count - 1);
                _blueBandIndex = Math.Clamp(_blueBandIndex, 0, _bandOptions.Count - 1);
            }

            // Auto-switch to RGB if ≥3 bands and first load
            if (_bandOptions.Count >= 3 && _viewMode == "Single" && _bandPreviewBase64 is null)
                _viewMode = "RGB";

            // Request canvas init on next render (after DOM has the new image)
            _canvasInitialized = false;
            _needsCanvasInit = true;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Raster Error",
                ex.Message, duration: 5000);
            _hasRaster = false;
            _mode = "csv";
        }
        finally
        {
            _isLoadingPreview = false;
            StateHasChanged();
        }
    }

    private async Task OnViewModeChanged()
    {
        await LoadBandPreview();
    }

    private async Task InitCanvas()
    {
        if (_image is null || _canvasInitialized) return;

        // Dispose previous DotNetRef if re-initializing
        _dotNetRef?.Dispose();
        _dotNetRef = DotNetObjectReference.Create(this);

        await JSRuntime.InvokeVoidAsync("trainingSelection.init",
            "training-selection-canvas", "training-preview-img",
            _dotNetRef, _image.Columns, _image.Rows);

        if (_selectedClass is not null)
        {
            var color = _classOptions.FirstOrDefault(c => c.Name == _selectedClass)?.Color ?? "#808080";
            await JSRuntime.InvokeVoidAsync("trainingSelection.setActiveClass", _selectedClass, color);
        }

        _canvasInitialized = true;
    }

    /// <summary>
    /// Re-draws existing regions on the canvas after band change or re-init.
    /// Converts raster pixel coordinates to display coordinates via JS addRegion
    /// (which performs the raster→display conversion using current scale).
    /// </summary>
    private async Task RehydrateRegionsOnCanvas()
    {
        await JSRuntime.InvokeVoidAsync("trainingSelection.clearAll");
        foreach (var r in _regions)
        {
            await JSRuntime.InvokeVoidAsync("trainingSelection.addRegion",
                r.StartCol, r.StartRow, r.EndCol, r.EndRow, r.Color, r.ClassName);
        }
    }

    private async Task OnBandChanged()
    {
        await LoadBandPreview();
    }

    private async Task OnClassChanged()
    {
        if (_selectedClass is null) return;
        var color = _classOptions.FirstOrDefault(c => c.Name == _selectedClass)?.Color ?? "#808080";
        if (_canvasInitialized)
            await JSRuntime.InvokeVoidAsync("trainingSelection.setActiveClass", _selectedClass, color);
    }

    private async Task SelectClass(string name)
    {
        _selectedClass = name;
        await OnClassChanged();
    }

    private async Task SwitchToDrawMode()
    {
        _mode = "draw";
        if (_bandPreviewBase64 is null && _hasRaster)
            await LoadBandPreview();
    }

    /// <summary>
    /// Called from JS when a rectangle is completed.
    /// </summary>
    [JSInvokable]
    public async Task OnRegionSelected(string className, int startRow, int startCol, int endRow, int endCol)
    {
        if (_image is null) return;

        var color = _classOptions.FirstOrDefault(c => c.Name == className)?.Color ?? "#808080";
        var region = new TrainingRegion(className, color, startRow, startCol, endRow, endCol);
        _regions.Add(region);

        var newSamples = await Task.Run(() =>
            PixelExtractor.ExtractRegion(_image, className, startRow, startCol, endRow, endCol));
        _samples.AddRange(newSamples);
        _bandNames = _image.BandNames.ToList();

        UpdateClassCards();
        UpdateSpectralChart();

        await InvokeAsync(StateHasChanged);
    }

    private async Task RemoveRegion(int index)
    {
        if (index < 0 || index >= _regions.Count) return;

        _regions.RemoveAt(index);

        // Rebuild samples from remaining regions
        _samples.Clear();
        if (_image is not null)
        {
            foreach (var r in _regions)
            {
                _samples.AddRange(PixelExtractor.ExtractRegion(
                    _image, r.ClassName, r.StartRow, r.StartCol, r.EndRow, r.EndCol));
            }
        }

        UpdateClassCards();
        UpdateSpectralChart();

        await JSRuntime.InvokeVoidAsync("trainingSelection.removeRegion", index);
    }

    private async Task ClearAllRegions()
    {
        _regions.Clear();
        _samples.Clear();
        UpdateClassCards();
        _spectralSeries.Clear();
        await JSRuntime.InvokeVoidAsync("trainingSelection.clearAll");
    }

    // --- CSV Upload ---

    private async Task OnCsvUploaded(InputFileChangeEventArgs e)
    {
        _mode = "csv";
        var file = e.File;
        if (file is null) return;

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var (samples, bandNames, warnings) = await Task.Run(() =>
            {
                using var ms = new MemoryStream();
                stream.CopyTo(ms);
                ms.Position = 0;
                return TrainingService.LoadSamplesFromCsv(ms);
            });

            _samples = samples;
            _bandNames = bandNames;
            _regions.Clear();

            // Clear JS regions to stay in sync
            if (_canvasInitialized)
                await JSRuntime.InvokeVoidAsync("trainingSelection.clearAll");

            if (warnings.Count > 0)
            {
                var shown = warnings.Take(5).ToList();
                var msg = string.Join("\n", shown);
                if (warnings.Count > 5)
                    msg += $"\n...and {warnings.Count - 5} more warning(s).";
                NotificationService.Notify(NotificationSeverity.Warning, "CSV Warnings", msg, duration: 8000);
            }

            if (samples.Count == 0)
            {
                NotificationService.Notify(NotificationSeverity.Error, "No Samples",
                    "No valid training samples found in the CSV.", duration: 4000);
                return;
            }

            UpdateClassCards();
            UpdateSpectralChart();

            NotificationService.Notify(NotificationSeverity.Success, "Samples Loaded",
                $"{samples.Count} samples from {file.Name}.", duration: 4000);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "CSV Error",
                ex.Message, duration: 5000);
        }
    }

    // --- Shared logic ---

    private void UpdateClassCards()
    {
        var classCounts = _samples.GroupBy(s => s.ClassName)
            .ToDictionary(g => g.Key, g => g.Count());

        var colorMap = _classOptions.ToDictionary(c => c.Name, c => c.Color);

        _classCards = _classOptions
            .Select(c => new ClassCard(c.Name, c.Color, classCounts.GetValueOrDefault(c.Name, 0)))
            .ToList();

        foreach (var kvp in classCounts.Where(kv => !colorMap.ContainsKey(kv.Key)))
            _classCards.Add(new ClassCard(kvp.Key, "#808080", kvp.Value));

        _selectedClass ??= _classCards.FirstOrDefault()?.Name;
    }

    private void UpdateSpectralChart()
    {
        _spectralSeries = [];
        var colorMap = _classOptions.ToDictionary(c => c.Name, c => c.Color);

        var grouped = _samples.GroupBy(s => s.ClassName);
        foreach (var group in grouped)
        {
            var points = new List<SpectralPoint>();
            foreach (var band in _bandNames)
            {
                var mean = group.Average(s => s.BandValues.GetValueOrDefault(band, 0));
                points.Add(new SpectralPoint(band, Math.Round(mean, 2)));
            }

            _spectralSeries.Add(new SpectralSeries(
                group.Key,
                colorMap.GetValueOrDefault(group.Key, "#808080"),
                points
            ));
        }
    }

    private async Task ExtractStatistics()
    {
        if (_samples.Count == 0) return;

        _isProcessing = true;
        StateHasChanged();

        try
        {
            var session = await Task.Run(() => TrainingService.CreateSession(_samples));
            ProjectState.TrainingSession = session;

            NotificationService.Notify(NotificationSeverity.Success, "Training Session Created",
                $"{session.ClassNames.Count} classes, {session.BandNames.Count} bands, {_samples.Count} samples. Ready to classify!",
                duration: 5000);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Extraction Failed",
                ex.Message, duration: 5000);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task ExportCsv()
    {
        if (_samples.Count == 0) return;

        var csv = TrainingService.ExportSamplesCsv(_samples, _bandNames);
        var fileName = $"training_samples_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        await JSRuntime.InvokeVoidAsync("downloadFile", fileName, "text/csv", csv);

        NotificationService.Notify(NotificationSeverity.Success, "Exported",
            $"{_samples.Count} samples saved as {fileName}.", duration: 4000);
    }

    private async Task ExportSession()
    {
        if (!ProjectState.HasTrainingSession) return;

        try
        {
            var json = TrainingService.ExportSessionJson(ProjectState.TrainingSession!);
            var projectName = ProjectState.Configuration?.ProjectName ?? "session";
            var safeName = string.Join("_", projectName.Split(Path.GetInvalidFileNameChars())).Trim('_');
            if (string.IsNullOrWhiteSpace(safeName)) safeName = "session";
            var fileName = $"{safeName}_training.json";

            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, "application/json", json);

            NotificationService.Notify(NotificationSeverity.Success, "Exported",
                $"Training session exported as {fileName}.", duration: 4000);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Export Failed",
                ex.Message, duration: 5000);
        }
    }

    private record ClassCard(string Name, string Color, int Samples);
    private record ClassOption(string Name, string Color);
    private record BandOption(string Name, int Index);
    private record SpectralPoint(string Band, double Value);
    private record SpectralSeries(string Name, string Color, List<SpectralPoint> Points);
}
