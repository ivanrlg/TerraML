@page "/classification"
@rendermode InteractiveServer
@implements IDisposable
@inject NotificationService NotificationService
@inject ProjectStateService ProjectState
@inject RasterService RasterService
@inject ClassificationService ClassificationSvc
@inject HybridClassificationService HybridClassificationSvc
@inject IJSRuntime JSRuntime

<PageTitle>Classification - FuzzySat</PageTitle>

<div class="classification-page fs-fade-in">
    <div class="page-header">
        <div>
            <h1 class="page-title">Classification</h1>
            <p class="page-subtitle">Configure and run fuzzy inference to classify each pixel into a land cover class.</p>
        </div>
        <span class="fs-badge fs-badge-blue">Step 3 of 4</span>
    </div>

    @if (!ProjectState.HasTrainingSession)
    {
        <div class="fs-card" style="text-align: center; padding: 3rem;">
            <span class="material-icons" style="font-size: 3rem; color: var(--fs-text-tertiary); margin-bottom: 1rem;">model_training</span>
            <h3 style="color: var(--fs-text-secondary);">No Training Session</h3>
            <p style="color: var(--fs-text-tertiary);">
                Upload training samples in <a href="/training" style="color: var(--fs-accent-blue);">Training</a> first,
                then return here to classify.
            </p>
        </div>
    }
    else
    {
        @* Classification Method Card *@
        <div class="fs-card" style="margin-bottom: 1.5rem;">
            <div class="section-header">
                <span class="material-icons section-icon">hub</span>
                <span class="section-title">Classification Method</span>
            </div>
            <div class="config-grid" style="margin-top: 1rem;">
                @foreach (var method in _classificationMethods)
                {
                    var isActive = _classificationMethod == method.Name;
                    <div class="config-card @(isActive ? "config-active" : "")" style="cursor: pointer;" @onclick="() => { if (!_isRunning) _classificationMethod = method.Name; }">
                        <div class="config-card-header">
                            <span class="material-icons config-icon" style="color: @method.Color;">@method.Icon</span>
                            <span class="config-label">@method.Name</span>
                        </div>
                        <div class="mf-preview">
                            <div class="mf-text-display">
                                <span class="mf-formula mono-text" style="font-size: 0.75rem;">@method.Formula</span>
                                <span class="mf-hint">@method.Hint</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
            @if (_classificationMethod != "Pure Fuzzy")
            {
                <div style="margin-top: 0.75rem; padding: 0.5rem 0.75rem; background: rgba(59, 130, 246, 0.08); border-radius: 8px; border-left: 3px solid var(--fs-accent-blue);">
                    <span style="color: var(--fs-text-secondary); font-size: 0.82rem;">
                        <span class="material-icons" style="font-size: 0.9rem; vertical-align: middle; margin-right: 0.25rem;">info</span>
                        Fuzzy membership degrees are used as enriched features for ML.NET training.
                        @if (!HasTrainingSamples)
                        {
                            <strong style="color: var(--fs-accent-amber);"> Requires training samples — draw regions in Training first.</strong>
                        }
                    </span>
                </div>
            }
        </div>

        @* Configuration Cards *@
        <div class="config-grid">
            <div class="config-card @(_mfType == "Gaussian" ? "config-active" : "")">
                <div class="config-card-header">
                    <span class="material-icons config-icon" style="color: var(--fs-accent-blue);">functions</span>
                    <span class="config-label">Membership Function</span>
                </div>
                <div class="mf-preview">
                    @switch (_mfType)
                    {
                        case "Gaussian":
                            <svg viewBox="0 0 120 50" class="mf-svg">
                                <path d="M 5 45 Q 20 45 35 40 Q 50 30 60 8 Q 70 30 75 40 Q 90 45 115 45" fill="none" stroke="#3B82F6" stroke-width="2"/>
                                <line x1="5" y1="45" x2="115" y2="45" stroke="#2A3558" stroke-width="1"/>
                            </svg>
                            break;
                        case "Triangular":
                            <svg viewBox="0 0 120 50" class="mf-svg">
                                <polyline points="5,45 60,5 115,45" fill="none" stroke="#06B6D4" stroke-width="2"/>
                                <line x1="5" y1="45" x2="115" y2="45" stroke="#2A3558" stroke-width="1"/>
                            </svg>
                            break;
                        case "Trapezoidal":
                            <svg viewBox="0 0 120 50" class="mf-svg">
                                <polyline points="5,45 30,5 90,5 115,45" fill="none" stroke="#10B981" stroke-width="2"/>
                                <line x1="5" y1="45" x2="115" y2="45" stroke="#2A3558" stroke-width="1"/>
                            </svg>
                            break;
                        case "Bell":
                            <svg viewBox="0 0 120 50" class="mf-svg">
                                <path d="M 5 45 Q 5 45 25 44 Q 40 42 48 30 Q 55 10 60 8 Q 65 10 72 30 Q 80 42 95 44 Q 115 45 115 45" fill="none" stroke="#8B5CF6" stroke-width="2"/>
                                <line x1="5" y1="45" x2="115" y2="45" stroke="#2A3558" stroke-width="1"/>
                            </svg>
                            break;
                    }
                </div>
                <RadzenDropDown @bind-Value="@_mfType" Data="@_mfTypes" Style="width: 100%;" Disabled="@_isRunning" />
            </div>

            <div class="config-card">
                <div class="config-card-header">
                    <span class="material-icons config-icon" style="color: var(--fs-accent-emerald);">join_inner</span>
                    <span class="config-label">AND Operator</span>
                </div>
                <div class="mf-preview">
                    <div class="mf-text-display">
                        <span class="mf-formula mono-text">@(_andOperator == "Minimum" ? "min(a, b)" : "a × b")</span>
                        <span class="mf-hint">@(_andOperator == "Minimum" ? "Weakest link rule" : "Algebraic product")</span>
                    </div>
                </div>
                <RadzenDropDown @bind-Value="@_andOperator" Data="@_andOperators" Style="width: 100%;" Disabled="@_isRunning" />
            </div>

            <div class="config-card">
                <div class="config-card-header">
                    <span class="material-icons config-icon" style="color: var(--fs-accent-amber);">output</span>
                    <span class="config-label">Defuzzifier</span>
                </div>
                <div class="mf-preview">
                    <div class="mf-text-display">
                        <span class="mf-formula mono-text">@(_defuzzifier == "Max Weight" ? "argmax(w)" : "\u03A3(w\u00B7c)/\u03A3w")</span>
                        <span class="mf-hint">@(_defuzzifier == "Max Weight" ? "Highest strength wins" : "Weighted combination")</span>
                    </div>
                </div>
                <RadzenDropDown @bind-Value="@_defuzzifier" Data="@_defuzzifiers" Style="width: 100%;" Disabled="@_isRunning" />
            </div>
        </div>

        @* Progress Section *@
        <div class="progress-section">
            <div class="progress-header">
                <span class="material-icons" style="color: var(--fs-accent-blue); font-size: 1.1rem;">speed</span>
                <span class="progress-title">Classification Progress</span>
                <span class="progress-pct mono-text">@($"{_progress:F0}%")</span>
            </div>

            <div class="progress-stages">
                @foreach (var stage in _stages)
                {
                    var stageClass = GetStageClass(stage.Order);
                    <div class="stage @stageClass">
                        <span class="stage-icon material-icons">@(stageClass == "stage-done" ? "check_circle" : stageClass == "stage-active" ? "pending" : "radio_button_unchecked")</span>
                        <span class="stage-name">@stage.Name</span>
                    </div>
                }
            </div>

            <RadzenProgressBar Value="@_progress" ShowValue="false" Style="height: 6px;" class="rz-mt-2" />
            <p class="status-msg">@_statusMessage</p>
        </div>

        @* Action Buttons *@
        <div class="action-row">
            @if (_isRunning)
            {
                <RadzenButton Text="Cancel" Icon="stop" ButtonStyle="ButtonStyle.Danger" Click="@CancelClassification" />
            }
            else
            {
                <RadzenButton Text="Run Classification" Icon="play_arrow" ButtonStyle="ButtonStyle.Primary"
                              Click="@RunClassification" class="run-btn"
                              Disabled="@(!CanRun)" />
            }
            <RadzenButton Text="Export Result" Icon="download" ButtonStyle="ButtonStyle.Secondary"
                          Disabled="@(!_completed)" Click="@ExportResult" />
        </div>

        @if (_completed && _classCounts is not null)
        {
            <div class="fs-card" style="margin-top: 1.5rem;">
                <div class="section-header">
                    <span class="material-icons section-icon">pie_chart</span>
                    <span class="section-title">Classification Summary</span>
                    <span class="fs-badge @(_classificationMethod == "Pure Fuzzy" ? "fs-badge-blue" : "fs-badge-emerald")" style="margin-left: auto;">@_classificationMethod</span>
                </div>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.75rem; margin-top: 1rem;">
                    @foreach (var (className, count) in _classCounts)
                    {
                        <div style="display: flex; justify-content: space-between; padding: 0.5rem 0.75rem; background: var(--fs-bg-tertiary); border-radius: 8px;">
                            <span style="color: var(--fs-text-secondary);">@className</span>
                            <span class="mono-text" style="color: var(--fs-text-primary);">@count.ToString("N0")</span>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    private string _classificationMethod = "Pure Fuzzy";
    private string _mfType = "Gaussian";
    private string _andOperator = "Minimum";
    private string _defuzzifier = "Max Weight";
    private double _progress = 0;
    private string _statusMessage = "Ready to classify. Configure parameters and press Run.";
    private bool _completed = false;
    private bool _isRunning = false;
    private int _currentStage = 0;
    private CancellationTokenSource? _cts;
    private List<KeyValuePair<string, int>>? _classCounts;

    private bool HasTrainingSamples => ProjectState.TrainingSamples is { Count: > 0 };

    private bool CanRun => ProjectState.HasTrainingSession
                           && ProjectState.Configuration?.InputRasterPath is not null
                           && (_classificationMethod == "Pure Fuzzy" || HasTrainingSamples);

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = null;
    }

    private List<string> _mfTypes = ["Gaussian", "Triangular", "Trapezoidal", "Bell"];
    private List<string> _andOperators = ["Minimum", "Product"];
    private List<string> _defuzzifiers = ["Max Weight", "Weighted Average"];

    private static readonly List<MethodInfo> _classificationMethods =
    [
        new("Pure Fuzzy", "functions", "var(--fs-accent-blue)", "Fuzzy Inference", "Direct fuzzy logic classification"),
        new("Random Forest", "park", "var(--fs-accent-emerald)", "ML.NET + 100 Trees", "Ensemble of decision trees with fuzzy features"),
        new("SDCA", "model_training", "var(--fs-accent-amber)", "Max Entropy", "Stochastic Dual Coordinate Ascent classifier")
    ];

    private record MethodInfo(string Name, string Icon, string Color, string Formula, string Hint);

    private List<StageInfo> _stages =
    [
        new(1, "Loading Raster"),
        new(2, "Computing MFs"),
        new(3, "Fuzzy Inference"),
        new(4, "Writing Output")
    ];

    private string GetStageClass(int order)
    {
        if (order < _currentStage) return "stage-done";
        if (order == _currentStage) return "stage-active";
        return "stage-pending";
    }

    private async Task RunClassification()
    {
        if (!CanRun) return;

        _cts?.Dispose();
        _cts = new CancellationTokenSource();
        _isRunning = true;
        _completed = false;
        _progress = 0;
        _currentStage = 1;
        _classCounts = null;
        _statusMessage = "Loading raster bands...";
        StateHasChanged();

        try
        {
            // Build options
            var rasterPath = ProjectState.Configuration!.InputRasterPath!;
            var bandNames = ProjectState.TrainingSession!.BandNames;
            var session = ProjectState.TrainingSession!;
            var options = new ClassificationOptions(_classificationMethod, _mfType, _andOperator, _defuzzifier);

            // Create progress handler on Blazor thread (Progress<T> captures sync context)
            var progress = new Progress<ClassificationProgress>(p =>
            {
                _progress = p.Percentage;
                _currentStage = p.Stage switch
                {
                    "Building membership functions" => 2,
                    "Initializing inference engine" => 2,
                    "Training ML model" or "ML model trained" => 2,
                    "Classifying pixels" => 3,
                    "Building result" => 4,
                    "Complete" => 5,
                    _ => _currentStage
                };
                _statusMessage = p.Stage switch
                {
                    "Classifying pixels" => $"Classifying row {p.CurrentRow}/{p.TotalRows} ({p.Percentage:F0}%)",
                    "Training ML model" => $"Training {_classificationMethod} model... ({p.Percentage:F0}%)",
                    "ML model trained" => $"{_classificationMethod} model ready. Starting classification...",
                    _ => $"{p.Stage} ({p.Percentage:F0}%)"
                };
                StateHasChanged();
            });

            // Run raster loading + classification on background thread to avoid blocking UI
            var result = await Task.Run(() =>
            {
                var image = RasterService.ReadImage(rasterPath, bandNames);

                if (options.ClassificationMethod != "Pure Fuzzy")
                {
                    var samples = ProjectState.TrainingSamples!;
                    return HybridClassificationSvc.Classify(
                        image, session, samples, options, progress, _cts!.Token);
                }

                return ClassificationSvc.Classify(image, session, options, progress, _cts!.Token);
            });

            // Store result in project state
            ProjectState.ClassificationResult = result;

            // Compute class distribution
            var counts = new Dictionary<string, int>();
            for (var r = 0; r < result.Rows; r++)
                for (var c = 0; c < result.Columns; c++)
                {
                    var cls = result.GetClass(r, c);
                    counts[cls] = counts.GetValueOrDefault(cls) + 1;
                }
            _classCounts = counts.OrderByDescending(kv => kv.Value).ToList();

            _progress = 100;
            _currentStage = 5;
            _statusMessage = $"Classification complete ({_classificationMethod}). {result.Classes.Count} classes, {result.Rows * result.Columns:N0} pixels classified.";
            _completed = true;

            NotificationService.Notify(NotificationSeverity.Success, "Classification Complete",
                $"{result.Classes.Count} classes identified across {result.Rows * result.Columns:N0} pixels.", duration: 5000);
        }
        catch (OperationCanceledException)
        {
            _statusMessage = "Classification cancelled by user.";
            _currentStage = 0;
            _progress = 0;
        }
        catch (FileNotFoundException ex)
        {
            _statusMessage = "Raster file not found.";
            _currentStage = 0;
            _progress = 0;
            NotificationService.Notify(NotificationSeverity.Error, "File Not Found",
                $"Could not find raster: {ex.FileName}", duration: 6000);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error: {ex.Message}";
            _currentStage = 0;
            _progress = 0;
            NotificationService.Notify(NotificationSeverity.Error, "Classification Failed",
                ex.Message, duration: 6000);
        }
        finally
        {
            _isRunning = false;
        }
    }

    private void CancelClassification()
    {
        _cts?.Cancel();
    }

    private async Task ExportResult()
    {
        if (_classCounts is null) return;

        var lines = new System.Text.StringBuilder();
        lines.AppendLine("Class,Pixel Count,Percentage");

        var total = _classCounts.Sum(kv => kv.Value);
        foreach (var (className, count) in _classCounts)
        {
            var pct = total > 0 ? (double)count / total * 100 : 0;
            lines.AppendLine($"{ValidationService.CsvEscape(className)},{count},{pct:F2}");
        }
        lines.AppendLine();
        lines.AppendLine($"Total,{total},100.00");
        lines.AppendLine($"Method,{_classificationMethod}");
        lines.AppendLine($"MF Type,{_mfType}");
        lines.AppendLine($"AND Operator,{_andOperator}");
        lines.AppendLine($"Defuzzifier,{_defuzzifier}");

        var fileName = $"classification_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        await JSRuntime.InvokeVoidAsync("downloadFile", fileName, "text/csv", lines.ToString());

        NotificationService.Notify(NotificationSeverity.Success, "Exported",
            $"Classification summary saved as {fileName}.", duration: 4000);
    }

    private record StageInfo(int Order, string Name);
}
