    private void OpenColorPicker(string className)
    {
        _editingColorClass = className;
        _editingColorValue = _colorMap.GetValueOrDefault(className, "#888888");
    }

    private async Task ApplyColorChange()
    {
        if (_editingColorClass is null) return;

        _colorMap[_editingColorClass] = _editingColorValue;
        ProjectState.ClassColors = new Dictionary<string, string>(_colorMap);
        _editingColorClass = null;

        // Re-render classified image with new colors
        var result = ProjectState.ClassificationResult;
        if (result is not null && _viewerInitialized)
        {
            var png = await Task.Run(() => _renderer.Render(result, _colorMap));
            var base64 = Convert.ToBase64String(png);
            await JSRuntime.InvokeVoidAsync("classificationCanvas.setClassifiedImage", base64);
        }
    }

    [Microsoft.JSInterop.JSInvokable]
    public string GetPixelInfo(int row, int col)
    {
        var result = ProjectState.ClassificationResult;
        if (result is null || row < 0 || row >= result.Rows || col < 0 || col >= result.Columns)
            return "";

        var className = System.Net.WebUtility.HtmlEncode(result.GetClass(row, col));
        var confidence = result.GetConfidence(row, col);
        return $"<b>{className}</b> ({confidence:P0})<br/>Pixel [{row}, {col}]";
    }

    private async Task ExportResult()
    {
        if (_areaStats is null && _classCounts is null) return;

        var lines = new System.Text.StringBuilder();

        if (_areaStats is not null)
        {
            lines.AppendLine(_hasGeoTransform
                ? "Class,Pixel Count,Area (m²),Area (ha),Percentage"
                : "Class,Pixel Count,Percentage");

            foreach (var stat in _areaStats)
            {
                if (_hasGeoTransform)
                    lines.AppendLine($"{ValidationService.CsvEscape(stat.ClassName)},{stat.PixelCount},{stat.AreaM2:F0},{stat.AreaHectares:F2},{stat.Percentage:F2}");
                else
                    lines.AppendLine($"{ValidationService.CsvEscape(stat.ClassName)},{stat.PixelCount},{stat.Percentage:F2}");
            }

            var totalPixels = _areaStats.Sum(s => s.PixelCount);
            var totalArea = _areaStats.Sum(s => s.AreaM2);
            var totalHa = _areaStats.Sum(s => s.AreaHectares);
            if (_hasGeoTransform)
                lines.AppendLine($"Total,{totalPixels},{totalArea:F0},{totalHa:F2},100.00");
            else
                lines.AppendLine($"Total,{totalPixels},100.00");
        }

        lines.AppendLine();
        lines.AppendLine($"Method,{_classificationMethod}");
        lines.AppendLine($"MF Type,{_mfType}");
        lines.AppendLine($"AND Operator,{_andOperator}");
        lines.AppendLine($"Defuzzifier,{_defuzzifier}");

        var fileName = $"classification_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        await JSRuntime.InvokeVoidAsync("downloadFile", fileName, "text/csv", lines.ToString());

        NotificationService.Notify(NotificationSeverity.Success, "Exported",
            $"Classification summary saved as {fileName}.", duration: 4000);
    }

    private async Task ExportGeoTiff()
    {
        var result = ProjectState.ClassificationResult;
        if (result is null) return;

        try
        {
            var tempPath = Path.Combine(Path.GetTempPath(), $"fuzzysat_classified_{DateTime.Now:yyyyMMdd_HHmmss}.tif");
            var sourceInfo = ProjectState.RasterInfo;

            await Task.Run(() =>
            {
                var writer = new Core.Raster.GdalRasterWriter();
                writer.Write(tempPath, result, sourceInfo);
            });

            var bytes = await File.ReadAllBytesAsync(tempPath);
            var base64 = Convert.ToBase64String(bytes);
            var fileName = Path.GetFileName(tempPath);

            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, "image/tiff", base64, true);

            // Clean up temp file
            try { File.Delete(tempPath); } catch { }

            NotificationService.Notify(NotificationSeverity.Success, "GeoTIFF Exported",
                $"Classified raster saved as {fileName}.", duration: 4000);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Export Failed",
                ex.Message, duration: 6000);
        }
    }

