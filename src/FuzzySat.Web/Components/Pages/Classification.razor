    {
        if (_viewerInitialized)
            await JSRuntime.InvokeVoidAsync("classificationCanvas.zoomIn");
    }

    private async Task ZoomOut()
    {
        if (_viewerInitialized)
            await JSRuntime.InvokeVoidAsync("classificationCanvas.zoomOut");
    }

    private async Task ResetView()
    {
        if (_viewerInitialized)
            await JSRuntime.InvokeVoidAsync("classificationCanvas.resetView");
