@page "/classification"
@rendermode InteractiveServer
@implements IDisposable
@inject NotificationService NotificationService
@inject ProjectStateService ProjectState
@inject RasterService RasterService
@inject ClassificationService ClassificationSvc
@inject HybridClassificationService HybridClassificationSvc
@inject IJSRuntime JSRuntime

<PageTitle>Classification - FuzzySat</PageTitle>

<div class="classification-page fs-fade-in">
    <div class="page-header">
        <div>
            <h1 class="page-title">Classification</h1>
            <p class="page-subtitle">Configure and run fuzzy inference to classify each pixel into a land cover class.</p>
        </div>
        <span class="fs-badge fs-badge-blue">Step 3 of 4</span>
    </div>

    @if (!ProjectState.HasTrainingSession)
    {
        <div class="fs-card" style="text-align: center; padding: 3rem;">
            <span class="material-icons" style="font-size: 3rem; color: var(--fs-text-tertiary); margin-bottom: 1rem;">model_training</span>
            <h3 style="color: var(--fs-text-secondary);">No Training Session</h3>
            <p style="color: var(--fs-text-tertiary);">
                Upload training samples in <a href="/training" style="color: var(--fs-accent-blue);">Training</a> first,
                then return here to classify.
            </p>
        </div>
    }
    else
    {
        @* Classification Method Card *@
        <div class="fs-card" style="margin-bottom: 1.5rem;">
            <div class="section-header">
                <span class="material-icons section-icon">hub</span>
                <span class="section-title">Classification Method</span>
            </div>
            @foreach (var group in _classificationMethods.GroupBy(m => m.Category))
            {
                <div style="margin-top: 1rem;">
                    <span style="font-size: 0.78rem; font-weight: 600; color: var(--fs-text-tertiary); text-transform: uppercase; letter-spacing: 0.05em;">@group.Key</span>
                </div>
                <div class="config-grid" style="margin-top: 0.4rem;">
                    @foreach (var method in group)
                    {
                        var isActive = _classificationMethod == method.Name;
                        <div class="config-card @(isActive ? "config-active" : "")" style="cursor: pointer;" @onclick="() => { if (!_isRunning) _classificationMethod = method.Name; }">
                            <div class="config-card-header">
                                <span class="material-icons config-icon" style="color: @method.Color;">@method.Icon</span>
                                <span class="config-label">@method.Name</span>
                            </div>
                            <div class="mf-preview">
                                <div class="mf-text-display">
                                    <span class="mf-formula mono-text" style="font-size: 0.75rem;">@method.Formula</span>
                                    <span class="mf-hint">@method.Hint</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            @if (_classificationMethod != "Pure Fuzzy")
            {
                <div style="margin-top: 0.75rem; padding: 0.5rem 0.75rem; background: rgba(59, 130, 246, 0.08); border-radius: 8px; border-left: 3px solid var(--fs-accent-blue);">
                    <span style="color: var(--fs-text-secondary); font-size: 0.82rem;">
                        <span class="material-icons" style="font-size: 0.9rem; vertical-align: middle; margin-right: 0.25rem;">info</span>
                        @if (_classificationMethod.StartsWith("ML: ", StringComparison.Ordinal))
                        {
                            <text>Raw spectral band values are used directly as features — no fuzzy feature engineering.</text>
                        }
                        else
                        {
                            <text>Fuzzy membership degrees are used as enriched features for ML.NET training.</text>
                        }
                        @if (!HasTrainingSamples)
                        {
                            <strong style="color: var(--fs-accent-amber);"> Requires training samples — draw regions in Training first.</strong>
                        }
                    </span>
                </div>
            }
        </div>

        @* Configuration Cards *@
        <div class="config-grid">
            <div class="config-card @(_mfType == "Gaussian" ? "config-active" : "")">
                <div class="config-card-header">
                    <span class="material-icons config-icon" style="color: var(--fs-accent-blue);">functions</span>
                    <span class="config-label">Membership Function</span>
                </div>
                <div class="mf-preview">
                    @switch (_mfType)
                    {
                        case "Gaussian":
                            <svg viewBox="0 0 120 50" class="mf-svg">
                                <path d="M 5 45 Q 20 45 35 40 Q 50 30 60 8 Q 70 30 75 40 Q 90 45 115 45" fill="none" stroke="#3B82F6" stroke-width="2"/>
                                <line x1="5" y1="45" x2="115" y2="45" stroke="#2A3558" stroke-width="1"/>
                            </svg>
                            break;
                        case "Triangular":
                            <svg viewBox="0 0 120 50" class="mf-svg">
                                <polyline points="5,45 60,5 115,45" fill="none" stroke="#06B6D4" stroke-width="2"/>
                                <line x1="5" y1="45" x2="115" y2="45" stroke="#2A3558" stroke-width="1"/>
                            </svg>
                            break;
                        case "Trapezoidal":
                            <svg viewBox="0 0 120 50" class="mf-svg">
                                <polyline points="5,45 30,5 90,5 115,45" fill="none" stroke="#10B981" stroke-width="2"/>
                                <line x1="5" y1="45" x2="115" y2="45" stroke="#2A3558" stroke-width="1"/>
                            </svg>
                            break;
                        case "Bell":
                            <svg viewBox="0 0 120 50" class="mf-svg">
                                <path d="M 5 45 Q 5 45 25 44 Q 40 42 48 30 Q 55 10 60 8 Q 65 10 72 30 Q 80 42 95 44 Q 115 45 115 45" fill="none" stroke="#8B5CF6" stroke-width="2"/>
                                <line x1="5" y1="45" x2="115" y2="45" stroke="#2A3558" stroke-width="1"/>
                            </svg>
                            break;
                    }
                </div>
                <RadzenDropDown @bind-Value="@_mfType" Data="@_mfTypes" Style="width: 100%;" Disabled="@_isRunning" />
            </div>

            <div class="config-card">
                <div class="config-card-header">
                    <span class="material-icons config-icon" style="color: var(--fs-accent-emerald);">join_inner</span>
                    <span class="config-label">AND Operator</span>
                </div>
                <div class="mf-preview">
                    <div class="mf-text-display">
                        <span class="mf-formula mono-text">@(_andOperator == "Minimum" ? "min(a, b)" : "a × b")</span>
                        <span class="mf-hint">@(_andOperator == "Minimum" ? "Weakest link rule" : "Algebraic product")</span>
                    </div>
                </div>
                <RadzenDropDown @bind-Value="@_andOperator" Data="@_andOperators" Style="width: 100%;" Disabled="@_isRunning" />
            </div>

            <div class="config-card">
                <div class="config-card-header">
                    <span class="material-icons config-icon" style="color: var(--fs-accent-amber);">output</span>
                    <span class="config-label">Defuzzifier</span>
                </div>
                <div class="mf-preview">
                    <div class="mf-text-display">
                        <span class="mf-formula mono-text">@(_defuzzifier == "Max Weight" ? "argmax(w)" : "\u03A3(w\u00B7c)/\u03A3w")</span>
                        <span class="mf-hint">@(_defuzzifier == "Max Weight" ? "Highest strength wins" : "Weighted combination")</span>
                    </div>
                </div>
                <RadzenDropDown @bind-Value="@_defuzzifier" Data="@_defuzzifiers" Style="width: 100%;" Disabled="@_isRunning" />
            </div>
        </div>

        @* Progress Section *@
        <div class="progress-section">
            <div class="progress-header">
                <span class="material-icons" style="color: var(--fs-accent-blue); font-size: 1.1rem;">speed</span>
                <span class="progress-title">Classification Progress</span>
                <span class="progress-pct mono-text">@($"{_progress:F0}%")</span>
            </div>

            <div class="progress-stages">
                @foreach (var stage in _stages)
                {
                    var stageClass = GetStageClass(stage.Order);
                    <div class="stage @stageClass">
                        <span class="stage-icon material-icons">@(stageClass == "stage-done" ? "check_circle" : stageClass == "stage-active" ? "pending" : "radio_button_unchecked")</span>
                        <span class="stage-name">@stage.Name</span>
                    </div>
                }
            </div>

            <RadzenProgressBar Value="@_progress" ShowValue="false" Style="height: 6px;" class="rz-mt-2" />
            <p class="status-msg">@_statusMessage</p>
        </div>

        @* Action Buttons *@
        <div class="action-row">
            @if (_isRunning)
            {
                <RadzenButton Text="Cancel" Icon="stop" ButtonStyle="ButtonStyle.Danger" Click="@CancelClassification" />
            }
            else
            {
                <RadzenButton Text="Run Classification" Icon="play_arrow" ButtonStyle="ButtonStyle.Primary"
                              Click="@RunClassification" class="run-btn"
                              Disabled="@(!CanRun)" />
            }
            <RadzenButton Text="Export CSV" Icon="download" ButtonStyle="ButtonStyle.Secondary"
                          Disabled="@(!_completed)" Click="@ExportResult" />
            <RadzenButton Text="Download GeoTIFF" Icon="map" ButtonStyle="ButtonStyle.Secondary"
                          Disabled="@(!_completed)" Click="@ExportGeoTiff" />
        </div>

        @if (_completed && _classCounts is not null)
        {
            @* Area Statistics Table *@
            <div class="fs-card" style="margin-top: 1.5rem;">
                <div class="section-header">
                    <span class="material-icons section-icon">pie_chart</span>
                    <span class="section-title">Area Statistics</span>
                    <span class="fs-badge @(_classificationMethod == "Pure Fuzzy" ? "fs-badge-blue" : "fs-badge-emerald")" style="margin-left: auto;">@_classificationMethod</span>
                </div>
                <div style="overflow-x: auto; margin-top: 1rem;">
                    <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
                        <thead>
                            <tr style="border-bottom: 1px solid var(--fs-border);">
                                <th style="text-align: left; padding: 0.5rem; color: var(--fs-text-tertiary); font-weight: 600;">Class</th>
                                <th style="text-align: right; padding: 0.5rem; color: var(--fs-text-tertiary); font-weight: 600;">Pixels</th>
                                @if (_hasGeoTransform)
                                {
                                    <th style="text-align: right; padding: 0.5rem; color: var(--fs-text-tertiary); font-weight: 600;">Area (m²)</th>
                                    <th style="text-align: right; padding: 0.5rem; color: var(--fs-text-tertiary); font-weight: 600;">Area (ha)</th>
                                }
                                <th style="text-align: right; padding: 0.5rem; color: var(--fs-text-tertiary); font-weight: 600;">%</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_areaStats is not null)
                            {
                                @foreach (var stat in _areaStats)
                                {
                                    var color = _colorMap.GetValueOrDefault(stat.ClassName, "#888");
                                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.04);">
                                        <td style="padding: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
                                            <span style="width: 14px; height: 14px; border-radius: 3px; background: @color; flex-shrink: 0; cursor: pointer; border: 1px solid rgba(255,255,255,0.15);"
                                                  @onclick="() => OpenColorPicker(stat.ClassName)" title="Click to change color"></span>
                                            <span style="color: var(--fs-text-secondary);">@stat.ClassName</span>
                                        </td>
                                        <td class="mono-text" style="text-align: right; padding: 0.5rem; color: var(--fs-text-primary);">@stat.PixelCount.ToString("N0")</td>
                                        @if (_hasGeoTransform)
                                        {
                                            <td class="mono-text" style="text-align: right; padding: 0.5rem; color: var(--fs-text-primary);">@stat.AreaM2.ToString("N0")</td>
                                            <td class="mono-text" style="text-align: right; padding: 0.5rem; color: var(--fs-text-primary);">@stat.AreaHectares.ToString("N2")</td>
                                        }
                                        <td class="mono-text" style="text-align: right; padding: 0.5rem; color: var(--fs-text-primary);">@stat.Percentage.ToString("F1")%</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                @* Area Distribution Chart *@
                @if (_areaStats is not null && _areaStats.Count > 0)
                {
                    <div style="display: flex; gap: 1.5rem; margin-top: 1.25rem; flex-wrap: wrap;">
                        <div style="flex: 1; min-width: 250px;">
                            <RadzenChart Style="height: 220px;">
                                <RadzenPieSeries Data="@_areaStats" Title="Distribution"
                                    CategoryProperty="ClassName" ValueProperty="Percentage">
                                    <RadzenSeriesDataLabels Visible="true" />
                                </RadzenPieSeries>
                            </RadzenChart>
                        </div>
                        <div style="flex: 1; min-width: 250px;">
                            <RadzenChart Style="height: 220px;">
                                <RadzenBarSeries Data="@_areaStats"
                                    CategoryProperty="ClassName"
                                    ValueProperty="@(_hasGeoTransform ? "AreaHectares" : "PixelCount")"
                                    Title="@(_hasGeoTransform ? "Hectares" : "Pixels")">
                                    <RadzenSeriesDataLabels Visible="false" />
                                </RadzenBarSeries>
                                <RadzenCategoryAxis />
                                <RadzenValueAxis>
                                    <RadzenGridLines Visible="true" />
                                </RadzenValueAxis>
                            </RadzenChart>
                        </div>
                    </div>
                }
            </div>

            @* Color Picker Dialog *@
            @if (_editingColorClass is not null)
            {
                <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center;"
                     @onclick="() => _editingColorClass = null">
                    <div class="fs-card" style="padding: 1.5rem; min-width: 280px;" @onclick:stopPropagation="true">
                        <h4 style="margin: 0 0 1rem; color: var(--fs-text-primary);">Color for @_editingColorClass</h4>
                        <RadzenColorPicker @bind-Value="@_editingColorValue" ShowHSV="true" ShowRGBA="true" ShowButton="false" />
                        <div style="display: flex; gap: 0.5rem; margin-top: 1rem; justify-content: flex-end;">
                            <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="() => _editingColorClass = null" Size="ButtonSize.Small" />
                            <RadzenButton Text="Apply" ButtonStyle="ButtonStyle.Primary" Click="ApplyColorChange" Size="ButtonSize.Small" />
                        </div>
                    </div>
                </div>
            }

            @* Classified Image Viewer *@
            <div class="fs-card" style="margin-top: 1.5rem;">
                <div class="section-header">
                    <span class="material-icons section-icon">satellite_alt</span>
                    <span class="section-title">Classified Image</span>
                    <div style="margin-left: auto; display: flex; gap: 0.25rem;">
                        @foreach (var mode in _viewModes)
                        {
                            <button class="cv-mode-btn @(_viewMode == mode.Key ? "cv-mode-active" : "")"
                                    @onclick="() => SetViewMode(mode.Key)">
                                <span class="material-icons" style="font-size: 0.9rem;">@mode.Icon</span>
                                @mode.Label
                            </button>
                        }
                    </div>
                </div>

                <div style="display: flex; gap: 0.25rem; margin: 0.75rem 0;">
                    <RadzenButton Text="" Icon="zoom_in" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Light" Click="ZoomIn" />
                    <RadzenButton Text="" Icon="zoom_out" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Light" Click="ZoomOut" />
                    <RadzenButton Text="" Icon="fit_screen" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Light" Click="ResetView" />
                    <span style="color: var(--fs-text-tertiary); font-size: 0.75rem; align-self: center; margin-left: 0.5rem;">Ctrl+drag to pan, scroll to zoom</span>
                </div>

                <div id="cv-viewer-container" style="display: flex; gap: 8px; position: relative; background: var(--fs-bg-tertiary); border-radius: 8px; overflow: hidden; min-height: 300px;">
                    <div class="cv-canvas-wrapper" style="flex: 1; position: relative;">
                        <span class="cv-canvas-label">Original</span>
                        <canvas class="cv-canvas-left" style="width: 100%; display: block;"></canvas>
                    </div>
                    <div class="cv-canvas-wrapper" style="flex: 1; position: relative;">
                        <span class="cv-canvas-label">Classified</span>
                        <canvas class="cv-canvas-right" style="width: 100%; display: block;"></canvas>
                    </div>
                    <div class="cv-tooltip" style="display: none; position: absolute; background: rgba(13,17,23,0.92); color: #e6edf3; padding: 4px 8px; border-radius: 6px; font-size: 0.75rem; pointer-events: none; z-index: 10; white-space: nowrap;"></div>
                </div>

                @* Color Legend *@
                <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 0.75rem; padding: 0.5rem 0;">
                    @foreach (var cls in _colorMap)
                    {
                        <div style="display: flex; align-items: center; gap: 0.35rem;">
                            <span style="width: 12px; height: 12px; border-radius: 2px; background: @cls.Value; border: 1px solid rgba(255,255,255,0.15);"></span>
                            <span style="color: var(--fs-text-secondary); font-size: 0.8rem;">@cls.Key</span>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "method")]
    public string? MethodFromQuery { get; set; }

    private string _classificationMethod = "Pure Fuzzy";
    private string _mfType = "Gaussian";
    private string _andOperator = "Minimum";
    private string _defuzzifier = "Max Weight";
    private double _progress = 0;
    private string _statusMessage = "Ready to classify. Configure parameters and press Run.";
    private bool _completed = false;
    private bool _isRunning = false;
    private int _currentStage = 0;
    private CancellationTokenSource? _cts;
    private List<KeyValuePair<string, int>>? _classCounts;
    private IReadOnlyList<Core.Classification.AreaCalculator.ClassAreaStats>? _areaStats;
    private bool _hasGeoTransform;

    // Image viewer state
    private Dictionary<string, string> _colorMap = new();
    private string _viewMode = "side-by-side";
    private DotNetObjectReference<Classification>? _dotNetRef;
    private bool _viewerInitialized = false;

    // Color picker state
    private string? _editingColorClass;
    private string _editingColorValue = "#3498DB";

    private static readonly ClassifiedImageRenderer _renderer = new();

    private bool HasTrainingSamples => ProjectState.TrainingSamples is { Count: > 0 };

    private bool _needsViewerInit;

    protected override void OnInitialized()
    {
        // Apply query parameter from "Use Best Model" navigation
        if (!string.IsNullOrEmpty(MethodFromQuery)
            && _classificationMethods.Any(m => m.Name == MethodFromQuery))
        {
            _classificationMethod = MethodFromQuery;
            _stages = GetStagesForMethod(_classificationMethod);
        }

        // Restore classification options from persisted state if no query param
        var saved = ProjectState.ClassificationOptions;
        if (saved is not null && string.IsNullOrEmpty(MethodFromQuery))
        {
            _classificationMethod = saved.ClassificationMethod;
            _mfType = saved.MembershipFunctionType;
            _andOperator = saved.AndOperator;
            _defuzzifier = saved.DefuzzifierType;
        }

        // Restore classification result from persisted state
        var result = ProjectState.ClassificationResult;
        if (result is not null)
        {
            // Recompute class distribution
            var counts = new Dictionary<string, int>();
            for (var r = 0; r < result.Rows; r++)
                for (var c = 0; c < result.Columns; c++)
                {
                    var cls = result.GetClass(r, c);
                    counts[cls] = counts.GetValueOrDefault(cls) + 1;
                }
            _classCounts = counts.OrderByDescending(kv => kv.Value).ToList();

            // Recompute area statistics
            var geoTransform = ProjectState.RasterInfo?.GeoTransform;
            _hasGeoTransform = geoTransform is { Length: >= 6 } && Math.Abs(geoTransform[1]) > 0;
            _areaStats = Core.Classification.AreaCalculator.Calculate(result, geoTransform);

            // Build color map
            _colorMap = ClassifiedImageRenderer.BuildColorMap(result.Classes, ProjectState.ClassColors);

            _progress = 100;
            _currentStage = 5;
            _statusMessage = $"Classification restored ({_classificationMethod}). {result.Classes.Count} classes, {result.Rows * result.Columns:N0} pixels.";
            _completed = true;
            _needsViewerInit = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _needsViewerInit && ProjectState.ClassificationResult is not null)
        {
            _needsViewerInit = false;
            await InitializeViewer(ProjectState.ClassificationResult);
            StateHasChanged();
        }
    }

    private bool CanRun => ProjectState.HasTrainingSession
                           && ProjectState.Configuration?.InputRasterPath is not null
                           && (_classificationMethod == "Pure Fuzzy" || HasTrainingSamples);

    private static readonly List<ViewModeInfo> _viewModes =
    [
        new("side-by-side", "view_column", "Side by Side"),
        new("original", "image", "Original"),
        new("classified", "palette", "Classified"),
        new("overlay", "layers", "Overlay")
    ];

    private record ViewModeInfo(string Key, string Icon, string Label);

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = null;
        _dotNetRef?.Dispose();
        _dotNetRef = null;
        _ = DisposeViewer();
    }

    private async Task DisposeViewer()
    {
        try { await JSRuntime.InvokeVoidAsync("classificationCanvas.dispose"); } catch { }
    }

    private List<string> _mfTypes = ["Gaussian", "Triangular", "Trapezoidal", "Bell"];
    private List<string> _andOperators = ["Minimum", "Product"];
    private List<string> _defuzzifiers = ["Max Weight", "Weighted Average"];

    private static readonly List<MethodInfo> _classificationMethods =
    [
        // Fuzzy
        new("Pure Fuzzy", "functions", "var(--fs-accent-blue)", "Fuzzy Inference", "Direct fuzzy logic classification", "Fuzzy"),
        // Hybrid (Fuzzy + ML)
        new("Random Forest", "park", "var(--fs-accent-emerald)", "ML.NET + 100 Trees", "Decision trees with fuzzy features", "Hybrid"),
        new("SDCA", "model_training", "var(--fs-accent-amber)", "Max Entropy", "SDCA classifier with fuzzy features", "Hybrid"),
        new("LightGBM", "bolt", "var(--fs-accent-violet)", "Gradient Boosting", "LightGBM with fuzzy features", "Hybrid"),
        new("SVM", "linear_scale", "var(--fs-accent-cyan)", "LinearSvm/OVA", "SVM with fuzzy features", "Hybrid"),
        new("Logistic Regression", "query_stats", "var(--fs-accent-red)", "LbfgsMaxEntropy", "Logistic regression with fuzzy features", "Hybrid"),
        new("MLP Neural Network", "neurology", "var(--fs-accent-amber)", "TorchSharp MLP", "Neural network with fuzzy features", "Hybrid"),
        // Pure ML (raw bands only)
        new("ML: Random Forest", "park", "var(--fs-accent-emerald)", "ML.NET + 100 Trees", "Raw bands only — no fuzzy features", "Pure ML"),
        new("ML: SDCA", "model_training", "var(--fs-accent-amber)", "Max Entropy", "Raw bands only — no fuzzy features", "Pure ML"),
        new("ML: LightGBM", "bolt", "var(--fs-accent-violet)", "Gradient Boosting", "Raw bands only — no fuzzy features", "Pure ML"),
        new("ML: SVM", "linear_scale", "var(--fs-accent-cyan)", "LinearSvm/OVA", "Raw bands only — no fuzzy features", "Pure ML"),
        new("ML: Logistic Regression", "query_stats", "var(--fs-accent-red)", "LbfgsMaxEntropy", "Raw bands only — no fuzzy features", "Pure ML"),
        new("ML: MLP Neural Network", "neurology", "var(--fs-accent-amber)", "TorchSharp MLP", "Raw bands only — no fuzzy features", "Pure ML"),
        // Ensemble
        new("Ensemble (Voting)", "how_to_vote", "var(--fs-accent-emerald)", "Majority Vote", "Combines RF + SDCA + LightGBM by vote", "Ensemble"),
        new("Ensemble (Stacking)", "stacks", "var(--fs-accent-blue)", "Meta-Learner", "Stacked generalization with OOF predictions", "Ensemble")
    ];

    private record MethodInfo(string Name, string Icon, string Color, string Formula, string Hint, string Category);

    private List<StageInfo> _stages = GetStagesForMethod("Pure Fuzzy");

    private static List<StageInfo> GetStagesForMethod(string method) => method == "Pure Fuzzy"
        ?
        [
            new(1, "Loading Raster"),
            new(2, "Computing MFs"),
            new(3, "Fuzzy Inference"),
            new(4, "Writing Output")
        ]
        :
        [
            new(1, "Loading Raster"),
            new(2, "Building Features"),
            new(3, "Training Model"),
            new(4, "Classifying Pixels"),
            new(5, "Writing Output")
        ];

    private string GetStageClass(int order)
    {
        if (order < _currentStage) return "stage-done";
        if (order == _currentStage) return "stage-active";
        return "stage-pending";
    }

    private async Task RunClassification()
    {
        if (!CanRun) return;

        _cts?.Dispose();
        _cts = new CancellationTokenSource();
        _isRunning = true;
        _completed = false;
        _progress = 0;
        _currentStage = 1;
        _stages = GetStagesForMethod(_classificationMethod);
        _classCounts = null;
        _statusMessage = "Loading raster bands...";
        StateHasChanged();

        try
        {
            // Build options
            var rasterPath = ProjectState.Configuration!.InputRasterPath!;
            var bandNames = ProjectState.TrainingSession!.BandNames;
            var session = ProjectState.TrainingSession!;
            var options = new ClassificationOptions(_classificationMethod, _mfType, _andOperator, _defuzzifier);

            // Create progress handler on Blazor thread (Progress<T> captures sync context)
            var progress = new Progress<ClassificationProgress>(p =>
            {
                _progress = p.Percentage;
                _currentStage = _classificationMethod == "Pure Fuzzy"
                    ? p.Stage switch
                    {
                        "Building membership functions" => 2,
                        "Initializing inference engine" => 2,
                        "Classifying pixels" => 3,
                        "Building result" => 4,
                        "Complete" => 5,
                        _ => _currentStage
                    }
                    : p.Stage switch
                    {
                        "Building membership functions" => 2,
                        "Training ML model" => 3,
                        "ML model trained" => 3,
                        "Classifying pixels" => 4,
                        "Building result" => 5,
                        "Complete" => 6,
                        _ => _currentStage
                    };
                _statusMessage = p.Stage switch
                {
                    "Classifying pixels" => $"Classifying row {p.CurrentRow}/{p.TotalRows} ({p.Percentage:F0}%)",
                    "Training ML model" => $"Training {_classificationMethod} model... ({p.Percentage:F0}%)",
                    "ML model trained" => $"{_classificationMethod} model ready. Starting classification...",
                    _ => $"{p.Stage} ({p.Percentage:F0}%)"
                };
                StateHasChanged();
            });

            // Run raster loading + classification on background thread to avoid blocking UI
            var result = await Task.Run(() =>
            {
                var image = RasterService.ReadImage(rasterPath, bandNames);

                if (options.ClassificationMethod != "Pure Fuzzy")
                {
                    var samples = ProjectState.TrainingSamples!;
                    return HybridClassificationSvc.Classify(
                        image, session, samples, options, progress, _cts!.Token);
                }

                return ClassificationSvc.Classify(image, session, options, progress, _cts!.Token);
            });

            // Store result and options in project state
            ProjectState.ClassificationResult = result;
            ProjectState.ClassificationOptions = options;

            // Compute class distribution
            var counts = new Dictionary<string, int>();
            for (var r = 0; r < result.Rows; r++)
                for (var c = 0; c < result.Columns; c++)
                {
                    var cls = result.GetClass(r, c);
                    counts[cls] = counts.GetValueOrDefault(cls) + 1;
                }
            _classCounts = counts.OrderByDescending(kv => kv.Value).ToList();

            // Compute area statistics
            var geoTransform = ProjectState.RasterInfo?.GeoTransform;
            _hasGeoTransform = geoTransform is { Length: >= 6 } && Math.Abs(geoTransform[1]) > 0;
            _areaStats = Core.Classification.AreaCalculator.Calculate(result, geoTransform);

            _progress = 100;
            _currentStage = 5;
            _statusMessage = $"Classification complete ({_classificationMethod}). {result.Classes.Count} classes, {result.Rows * result.Columns:N0} pixels classified.";
            _completed = true;

            NotificationService.Notify(NotificationSeverity.Success, "Classification Complete",
                $"{result.Classes.Count} classes identified across {result.Rows * result.Columns:N0} pixels.", duration: 5000);

            // Build color map and render classified image
            _colorMap = ClassifiedImageRenderer.BuildColorMap(result.Classes, ProjectState.ClassColors);
            ProjectState.ClassColors = new Dictionary<string, string>(_colorMap);
            StateHasChanged();

            // Render images after DOM update
            await Task.Delay(100); // Let Blazor render the viewer markup
            await InitializeViewer(result);
        }
        catch (OperationCanceledException)
        {
            _statusMessage = "Classification cancelled by user.";
            _currentStage = 0;
            _progress = 0;
        }
        catch (FileNotFoundException ex)
        {
            _statusMessage = "Raster file not found.";
            _currentStage = 0;
            _progress = 0;
            NotificationService.Notify(NotificationSeverity.Error, "File Not Found",
                $"Could not find raster: {ex.FileName}", duration: 6000);
        }
        catch (Exception ex)
        {
            _statusMessage = $"Error: {ex.Message}";
            _currentStage = 0;
            _progress = 0;
            NotificationService.Notify(NotificationSeverity.Error, "Classification Failed",
                ex.Message, duration: 6000);
        }
        finally
        {
            _isRunning = false;
        }
    }

    private void CancelClassification()
    {
        _cts?.Cancel();
    }

    private async Task InitializeViewer(Core.Classification.ClassificationResult result)
    {
        try
        {
            _dotNetRef?.Dispose();
            _dotNetRef = DotNetObjectReference.Create(this);

            await JSRuntime.InvokeVoidAsync("classificationCanvas.init",
                "cv-viewer-container", _dotNetRef, result.Columns, result.Rows);

            // Render and send classified image
            var classifiedPng = await Task.Run(() => _renderer.Render(result, _colorMap));
            var classifiedBase64 = Convert.ToBase64String(classifiedPng);
            await JSRuntime.InvokeVoidAsync("classificationCanvas.setClassifiedImage", classifiedBase64);

            // Render and send original image (false color or grayscale)
            var originalPng = await Task.Run(() => RenderOriginalImage());
            if (originalPng is not null)
            {
                var originalBase64 = Convert.ToBase64String(originalPng);
                await JSRuntime.InvokeVoidAsync("classificationCanvas.setOriginalImage", originalBase64);
            }

            _viewerInitialized = true;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Viewer",
                $"Could not initialize image viewer: {ex.Message}", duration: 4000);
        }
    }

    private byte[]? RenderOriginalImage()
    {
        var image = ProjectState.CachedImage;
        if (image is null) return null;

        // Try RGB composite if 3+ bands, otherwise grayscale of first band
        if (image.BandNames.Count >= 3)
        {
            var r = image.GetBand(image.BandNames[0]);
            var g = image.GetBand(image.BandNames[1]);
            var b = image.GetBand(image.BandNames[2]);
            return RasterService.RenderRgbComposite(r, g, b,
                RasterService.ComputeBandStatistics(r), RasterService.ComputeBandStatistics(g),
                RasterService.ComputeBandStatistics(b));
        }
        else
        {
            var band = image.GetBand(image.BandNames[0]);
            return RasterService.RenderBandPreview(band, RasterService.ComputeBandStatistics(band));
        }
    }

    private async Task SetViewMode(string mode)
    {
        _viewMode = mode;
        if (_viewerInitialized)
            await JSRuntime.InvokeVoidAsync("classificationCanvas.setViewMode", mode);
    }

