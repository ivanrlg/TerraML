@page "/band-viewer"
@rendermode InteractiveServer
@inject ProjectStateService ProjectState
@inject RasterService RasterService
@inject NotificationService NotificationService
@inject ILogger<BandViewer> Logger

<PageTitle>Band Viewer - FuzzySat</PageTitle>

<div class="bandviewer-page fs-fade-in">
    <div class="page-header">
        <div>
            <h1 class="page-title">Band Viewer</h1>
            <p class="page-subtitle">Visualize spectral bands and RGB composites with statistics and histograms.</p>
        </div>
        <span class="fs-badge fs-badge-blue">Step 2 of 5</span>
    </div>

    @if (!ProjectState.HasProject || string.IsNullOrWhiteSpace(ProjectState.Configuration?.InputRasterPath))
    {
        <div class="fs-card" style="text-align: center; padding: 3rem;">
            <span class="material-icons" style="font-size: 3rem; color: var(--fs-text-tertiary); margin-bottom: 1rem;">layers</span>
            <h3 style="color: var(--fs-text-secondary);">No Project Loaded</h3>
            <p style="color: var(--fs-text-tertiary);">Configure a project with an input raster in <a href="/project-setup" style="color: var(--fs-accent-blue);">Project Setup</a> first.</p>
        </div>
    }
    else
    {
        @* Band Toolbar *@
        <div class="band-toolbar">
            <div class="toolbar-section">
                <span class="toolbar-label">View</span>
                <RadzenDropDown @bind-Value="@_viewMode" Data="@_viewModes"
                                Style="width: 140px;" Change="@(_ => OnViewModeChanged())" />
            </div>

            @if (_viewMode == "Single Band")
            {
                <div class="toolbar-section">
                    <span class="toolbar-label">Band</span>
                    <RadzenDropDown @bind-Value="@_selectedBand" Data="@_bandNames"
                                    Placeholder="Select band..." Style="width: 180px;"
                                    Change="@(_ => OnBandChanged())" />
                </div>
            }
            else
            {
                <div class="toolbar-section">
                    <span class="toolbar-label" style="color: #EF4444;">R</span>
                    <RadzenDropDown @bind-Value="@_redBand" Data="@_bandNames" Style="width: 120px;"
                                    Change="@(_ => OnRgbChanged())" />
                </div>
                <div class="toolbar-section">
                    <span class="toolbar-label" style="color: #10B981;">G</span>
                    <RadzenDropDown @bind-Value="@_greenBand" Data="@_bandNames" Style="width: 120px;"
                                    Change="@(_ => OnRgbChanged())" />
                </div>
                <div class="toolbar-section">
                    <span class="toolbar-label" style="color: #3B82F6;">B</span>
                    <RadzenDropDown @bind-Value="@_blueBand" Data="@_bandNames" Style="width: 120px;"
                                    Change="@(_ => OnRgbChanged())" />
                </div>
                @if (_availablePresets.Count > 0)
                {
                    <div class="toolbar-section">
                        <span class="toolbar-label">Preset</span>
                        <RadzenDropDown @bind-Value="@_selectedPreset" Data="@_availablePresets"
                                        TextProperty="Label" Style="width: 160px;"
                                        Change="@(_ => OnPresetChanged())" />
                    </div>
                }
            }

            <div class="toolbar-section">
                <span class="toolbar-label">Stretch</span>
                <RadzenDropDown @bind-Value="@_stretch" Data="@_stretches" Style="width: 140px;" Disabled="true" />
            </div>
            <div class="toolbar-spacer"></div>
            <div class="toolbar-section">
                <span class="toolbar-label">Opacity</span>
                <RadzenSlider @bind-Value="@_opacity" Min="0" Max="100" Step="5" Style="width: 100px;" />
                <span class="mono-text toolbar-val">@_opacity%</span>
            </div>
        </div>

        <div class="viewer-layout">
            @* Map / Preview Area *@
            <div class="map-area">
                @if (_isLoading)
                {
                    <div style="display: flex; align-items: center; justify-content: center; height: 520px; background: var(--fs-bg-surface); border-radius: var(--fs-radius-lg);">
                        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Large" />
                        <span style="margin-left: 1rem; color: var(--fs-text-secondary);">Loading @(_viewMode == "RGB Composite" ? "composite" : "band") data...</span>
                    </div>
                }
                else if (_bandPreviewBase64 is not null)
                {
                    <div style="background: var(--fs-bg-surface); border-radius: var(--fs-radius-lg); padding: 0.5rem; text-align: center;">
                        <img src="data:image/png;base64,@_bandPreviewBase64" alt="@(_viewMode == "RGB Composite" ? "RGB Composite" : "Band") preview"
                             style="max-width: 100%; max-height: 520px; border-radius: var(--fs-radius-md); opacity: @(_opacity / 100.0);" />
                    </div>
                }
                else
                {
                    <MapPlaceholder Height="520px" Message="Select a band to preview" Icon="layers" />
                }
            </div>

            @* Side Panel *@
            <div class="info-panel">
                <div class="info-section">
                    <div class="info-header">
                        <span class="material-icons" style="font-size: 1rem; color: var(--fs-accent-cyan);">info</span>
                        <span>@(_viewMode == "RGB Composite" ? "RGB Composite" : "Band Metadata")</span>
                    </div>
                    <div class="meta-grid">
                        @if (_viewMode == "RGB Composite")
                        {
                            <span class="meta-label">Red</span>
                            <span class="meta-value mono-text" style="color: #EF4444;">@(_redBand ?? "—")</span>
                            <span class="meta-label">Green</span>
                            <span class="meta-value mono-text" style="color: #10B981;">@(_greenBand ?? "—")</span>
                            <span class="meta-label">Blue</span>
                            <span class="meta-value mono-text" style="color: #3B82F6;">@(_blueBand ?? "—")</span>
                        }
                        else
                        {
                            <span class="meta-label">Band</span>
                            <span class="meta-value mono-text">@(_selectedBand ?? "None")</span>
                        }
                        <span class="meta-label">Dimensions</span>
                        <span class="meta-value mono-text">@(ProjectState.RasterInfo is not null ? $"{ProjectState.RasterInfo.Columns} x {ProjectState.RasterInfo.Rows}" : "—")</span>
                        <span class="meta-label">Data Type</span>
                        <span class="meta-value mono-text">@(ProjectState.RasterInfo?.DataType ?? "—")</span>
                        <span class="meta-label">Bands</span>
                        <span class="meta-value mono-text">@(ProjectState.RasterInfo?.BandCount.ToString() ?? "—")</span>
                    </div>
                </div>

                <div class="info-section">
                    <div class="info-header">
                        <span class="material-icons" style="font-size: 1rem; color: var(--fs-accent-blue);">bar_chart</span>
                        <span>Histogram</span>
                    </div>
                    @if (_histogramData.Count > 0)
                    {
                        <RadzenChart Style="height: 180px;">
                            <RadzenAreaSeries Data="@_histogramData" CategoryProperty="Bin" ValueProperty="Count"
                                              Stroke="#3B82F6" StrokeWidth="1.5" Fill="rgba(59, 130, 246, 0.15)">
                                <RadzenSeriesDataLabels Visible="false" />
                            </RadzenAreaSeries>
                            <RadzenCategoryAxis Visible="false" />
                            <RadzenValueAxis Visible="false">
                                <RadzenGridLines Visible="false" />
                            </RadzenValueAxis>
                        </RadzenChart>
                    }
                    else
                    {
                        <p style="color: var(--fs-text-tertiary); font-size: 0.85rem;">Select a band to view histogram.</p>
                    }
                </div>

                <div class="info-section">
                    <div class="info-header">
                        <span class="material-icons" style="font-size: 1rem; color: var(--fs-accent-emerald);">query_stats</span>
                        <span>Statistics</span>
                    </div>
                    <div class="meta-grid">
                        <span class="meta-label">Min</span>
                        <span class="meta-value mono-text">@(_stats?.Min.ToString("F2") ?? "—")</span>
                        <span class="meta-label">Max</span>
                        <span class="meta-value mono-text">@(_stats?.Max.ToString("F2") ?? "—")</span>
                        <span class="meta-label">Mean</span>
                        <span class="meta-value mono-text">@(_stats?.Mean.ToString("F2") ?? "—")</span>
                        <span class="meta-label">Std Dev</span>
                        <span class="meta-value mono-text">@(_stats?.StdDev.ToString("F2") ?? "—")</span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private string _viewMode = "Single Band";
    private string? _selectedBand;
    private string? _redBand;
    private string? _greenBand;
    private string? _blueBand;
    private string _stretch = "Min-Max";
    private double _opacity = 100;
    private bool _isLoading = false;
    private CompositePreset? _selectedPreset;

    private List<string> _bandNames = [];
    private List<string> _viewModes = ["Single Band", "RGB Composite"];
    private List<string> _stretches = ["Min-Max", "Std Dev", "Histogram Eq."];
    private List<CompositePreset> _availablePresets = [];

    private BandStatistics? _stats;
    private string? _bandPreviewBase64;
    private List<HistBin> _histogramData = [];
    private MultispectralImage? _loadedImage;

    // All known presets (filtered at runtime by available band names)
    // Includes aliases for common naming conventions (descriptive names AND Sentinel-2 codes)
    private static readonly CompositePreset[] AllPresets =
    [
        // Descriptive band names (from S2Preprocess tool)
        new("True Color", "Red", "Green", "Blue"),
        new("False Color IR", "NIR", "Red", "Green"),
        new("SWIR Composite", "SWIR1", "NIR", "Red"),
        new("Vegetation", "NIR", "SWIR1", "Red"),
        // Sentinel-2 standard codes (B02=Blue, B03=Green, B04=Red, B08=NIR, B11=SWIR1)
        new("True Color (S2)", "B04", "B03", "B02"),
        new("False Color IR (S2)", "B08", "B04", "B03"),
        new("SWIR (S2)", "B11", "B08", "B04"),
        // ASTER band names
        new("VNIR (ASTER)", "VNIR2", "VNIR1", "SWIR1"),
    ];

    protected override async Task OnInitializedAsync()
    {
        if (ProjectState.HasProject && !string.IsNullOrWhiteSpace(ProjectState.Configuration?.InputRasterPath))
        {
            _bandNames = ProjectState.Configuration.Bands?.Select(b => b.Name).ToList() ?? [];

            if (_bandNames.Count > 0)
            {
                _selectedBand = _bandNames[0];

                // Default RGB assignment (first 3 bands or best guess)
                _redBand = _bandNames.Count > 2 ? _bandNames[2] : _bandNames[0]; // Red band (index 2 for S2)
                _greenBand = _bandNames.Count > 1 ? _bandNames[1] : _bandNames[0]; // Green
                _blueBand = _bandNames[0]; // Blue

                // Force Single mode if < 3 bands
                if (_bandNames.Count < 3)
                    _viewMode = "Single Band";

                // Filter presets by available band names
                var nameSet = new HashSet<string>(_bandNames, StringComparer.OrdinalIgnoreCase);
                _availablePresets = AllPresets
                    .Where(p => nameSet.Contains(p.RedBand) && nameSet.Contains(p.GreenBand) && nameSet.Contains(p.BlueBand))
                    .ToList();

                if (!ProjectState.HasRasterInfo)
                {
                    try
                    {
                        var info = await Task.Run(() => RasterService.GetInfo(ProjectState.Configuration.InputRasterPath));
                        ProjectState.RasterInfo = info;
                    }
                    catch (Exception ex)
                    {
                        Logger.LogWarning(ex, "Failed to load raster info for BandViewer");
                    }
                }

                await LoadBandData();
            }
        }
    }

    private const long MaxPixels = 50_000_000;

    private async Task OnViewModeChanged()
    {
        if (_viewMode == "RGB Composite")
            await LoadRgbData();
        else
            await LoadBandData();
    }

    private async Task OnBandChanged()
    {
        if (_selectedBand is not null && !_isLoading)
            await LoadBandData();
    }

    private async Task OnRgbChanged()
    {
        _selectedPreset = null; // Clear preset when manually changed
        if (_redBand is not null && _greenBand is not null && _blueBand is not null && !_isLoading)
            await LoadRgbData();
    }

    private async Task OnPresetChanged()
    {
        if (_selectedPreset is null) return;
        _redBand = _selectedPreset.RedBand;
        _greenBand = _selectedPreset.GreenBand;
        _blueBand = _selectedPreset.BlueBand;
        await LoadRgbData();
    }

    private async Task LoadBandData()
    {
        if (_selectedBand is null || ProjectState.Configuration?.InputRasterPath is null) return;

        _isLoading = true;
        StateHasChanged();

        try
        {
            var info = ProjectState.RasterInfo;
            if (info is not null && (long)info.Rows * info.Columns * info.BandCount > MaxPixels)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Raster Too Large",
                    $"Raster ({info.Columns}x{info.Rows}, {info.BandCount} bands) exceeds the {MaxPixels / 1_000_000}M pixel limit.",
                    duration: 6000);
                return;
            }

            _loadedImage ??= await Task.Run(() =>
                RasterService.ReadImage(ProjectState.Configuration.InputRasterPath, _bandNames));

            var selectedBand = _selectedBand;
            var (stats, png) = await Task.Run(() =>
            {
                var band = _loadedImage.GetBand(selectedBand);
                var s = RasterService.ComputeBandStatistics(band);
                var p = RasterService.RenderBandPreview(band, s);
                return (s, p);
            });

            _stats = stats;
            _bandPreviewBase64 = Convert.ToBase64String(png);
            BuildHistogramData(stats);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load band data for '{Band}'", _selectedBand);
            NotificationService.Notify(NotificationSeverity.Error, "Load Error",
                "Failed to load band data. Check logs for details.", duration: 5000);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadRgbData()
    {
        if (_redBand is null || _greenBand is null || _blueBand is null ||
            ProjectState.Configuration?.InputRasterPath is null) return;

        _isLoading = true;
        StateHasChanged();

        try
        {
            var info = ProjectState.RasterInfo;
            if (info is not null && (long)info.Rows * info.Columns * info.BandCount > MaxPixels)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Raster Too Large",
                    $"Raster ({info.Columns}x{info.Rows}, {info.BandCount} bands) exceeds the {MaxPixels / 1_000_000}M pixel limit.",
                    duration: 6000);
                return;
            }

            _loadedImage ??= await Task.Run(() =>
                RasterService.ReadImage(ProjectState.Configuration.InputRasterPath, _bandNames));

            var rName = _redBand;
            var gName = _greenBand;
            var bName = _blueBand;

            var (rStats, png) = await Task.Run(() =>
            {
                var rBand = _loadedImage.GetBand(rName);
                var gBand = _loadedImage.GetBand(gName);
                var bBand = _loadedImage.GetBand(bName);
                var rs = RasterService.ComputeBandStatistics(rBand);
                var gs = RasterService.ComputeBandStatistics(gBand);
                var bs = RasterService.ComputeBandStatistics(bBand);
                var p = RasterService.RenderRgbComposite(rBand, gBand, bBand, rs, gs, bs);
                return (rs, p);
            });

            _stats = rStats; // Show red channel stats in panel
            _bandPreviewBase64 = Convert.ToBase64String(png);
            BuildHistogramData(rStats);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load RGB composite");
            NotificationService.Notify(NotificationSeverity.Error, "Load Error",
                "Failed to render RGB composite. Check logs for details.", duration: 5000);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void BuildHistogramData(BandStatistics stats)
    {
        _histogramData = [];
        for (var i = 0; i < 256; i += 4)
        {
            long sum = 0;
            for (var j = i; j < Math.Min(i + 4, 256); j++)
                sum += stats.Histogram[j];
            _histogramData.Add(new HistBin(i.ToString(), sum));
        }
    }

    private record HistBin(string Bin, long Count);
    private record CompositePreset(string Label, string RedBand, string GreenBand, string BlueBand);
}
