@page "/band-viewer"
@rendermode InteractiveServer
@inject ProjectStateService ProjectState
@inject RasterService RasterService
@inject NotificationService NotificationService

<PageTitle>Band Viewer - FuzzySat</PageTitle>

<div class="bandviewer-page fs-fade-in">
    <div class="page-header">
        <div>
            <h1 class="page-title">Band Viewer</h1>
            <p class="page-subtitle">Visualize spectral bands and false color composites on an interactive map.</p>
        </div>
        <span class="fs-badge fs-badge-blue">Step 2 of 5</span>
    </div>

    @if (!ProjectState.HasProject || string.IsNullOrWhiteSpace(ProjectState.Configuration?.InputRasterPath))
    {
        <div class="fs-card" style="text-align: center; padding: 3rem;">
            <span class="material-icons" style="font-size: 3rem; color: var(--fs-text-tertiary); margin-bottom: 1rem;">layers</span>
            <h3 style="color: var(--fs-text-secondary);">No Project Loaded</h3>
            <p style="color: var(--fs-text-tertiary);">Configure a project with an input raster in <a href="/project-setup" style="color: var(--fs-accent-blue);">Project Setup</a> first.</p>
        </div>
    }
    else
    {
        @* Band Toolbar *@
        <div class="band-toolbar">
            <div class="toolbar-section">
                <span class="toolbar-label">Band</span>
                <RadzenDropDown @bind-Value="@_selectedBand" Data="@_bandNames"
                                Placeholder="Select band..." Style="width: 180px;"
                                Change="@(_ => OnBandChanged())" />
            </div>
            <div class="toolbar-section">
                <span class="toolbar-label">Stretch</span>
                <RadzenDropDown @bind-Value="@_stretch" Data="@_stretches" Style="width: 140px;" />
            </div>
            <div class="toolbar-spacer"></div>
            <div class="toolbar-section">
                <span class="toolbar-label">Opacity</span>
                <RadzenSlider @bind-Value="@_opacity" Min="0" Max="100" Step="5" Style="width: 100px;" />
                <span class="mono-text toolbar-val">@_opacity%</span>
            </div>
        </div>

        <div class="viewer-layout">
            @* Map / Preview Area *@
            <div class="map-area">
                @if (_isLoading)
                {
                    <div style="display: flex; align-items: center; justify-content: center; height: 520px; background: var(--fs-bg-surface); border-radius: var(--fs-radius-lg);">
                        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Large" />
                        <span style="margin-left: 1rem; color: var(--fs-text-secondary);">Loading band data...</span>
                    </div>
                }
                else if (_bandPreviewBase64 is not null)
                {
                    <div style="background: var(--fs-bg-surface); border-radius: var(--fs-radius-lg); padding: 0.5rem; text-align: center;">
                        <img src="data:image/png;base64,@_bandPreviewBase64" alt="Band preview"
                             style="max-width: 100%; max-height: 520px; border-radius: var(--fs-radius-md); opacity: @(_opacity / 100.0);" />
                    </div>
                }
                else
                {
                    <MapPlaceholder Height="520px" Message="Select a band to preview" Icon="layers" />
                }
            </div>

            @* Side Panel *@
            <div class="info-panel">
                <div class="info-section">
                    <div class="info-header">
                        <span class="material-icons" style="font-size: 1rem; color: var(--fs-accent-cyan);">info</span>
                        <span>Band Metadata</span>
                    </div>
                    <div class="meta-grid">
                        <span class="meta-label">Band</span>
                        <span class="meta-value mono-text">@(_selectedBand ?? "None")</span>
                        <span class="meta-label">Dimensions</span>
                        <span class="meta-value mono-text">@(ProjectState.RasterInfo is not null ? $"{ProjectState.RasterInfo.Columns} x {ProjectState.RasterInfo.Rows}" : "—")</span>
                        <span class="meta-label">Data Type</span>
                        <span class="meta-value mono-text">@(ProjectState.RasterInfo?.DataType ?? "—")</span>
                        <span class="meta-label">Bands</span>
                        <span class="meta-value mono-text">@(ProjectState.RasterInfo?.BandCount.ToString() ?? "—")</span>
                    </div>
                </div>

                <div class="info-section">
                    <div class="info-header">
                        <span class="material-icons" style="font-size: 1rem; color: var(--fs-accent-blue);">bar_chart</span>
                        <span>Histogram</span>
                    </div>
                    @if (_histogramData.Count > 0)
                    {
                        <RadzenChart Style="height: 180px;">
                            <RadzenAreaSeries Data="@_histogramData" CategoryProperty="Bin" ValueProperty="Count"
                                              Stroke="#3B82F6" StrokeWidth="1.5" Fill="rgba(59, 130, 246, 0.15)">
                                <RadzenSeriesDataLabels Visible="false" />
                            </RadzenAreaSeries>
                            <RadzenCategoryAxis Visible="false" />
                            <RadzenValueAxis Visible="false">
                                <RadzenGridLines Visible="false" />
                            </RadzenValueAxis>
                        </RadzenChart>
                    }
                    else
                    {
                        <p style="color: var(--fs-text-tertiary); font-size: 0.85rem;">Select a band to view histogram.</p>
                    }
                </div>

                <div class="info-section">
                    <div class="info-header">
                        <span class="material-icons" style="font-size: 1rem; color: var(--fs-accent-emerald);">query_stats</span>
                        <span>Statistics</span>
                    </div>
                    <div class="meta-grid">
                        <span class="meta-label">Min</span>
                        <span class="meta-value mono-text">@(_stats?.Min.ToString("F2") ?? "—")</span>
                        <span class="meta-label">Max</span>
                        <span class="meta-value mono-text">@(_stats?.Max.ToString("F2") ?? "—")</span>
                        <span class="meta-label">Mean</span>
                        <span class="meta-value mono-text">@(_stats?.Mean.ToString("F2") ?? "—")</span>
                        <span class="meta-label">Std Dev</span>
                        <span class="meta-value mono-text">@(_stats?.StdDev.ToString("F2") ?? "—")</span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private string? _selectedBand;
    private string _stretch = "Min-Max";
    private double _opacity = 100;
    private bool _isLoading = false;

    private List<string> _bandNames = [];
    private List<string> _stretches = ["Min-Max", "Std Dev", "Histogram Eq."];

    private BandStatistics? _stats;
    private string? _bandPreviewBase64;
    private List<HistBin> _histogramData = [];
    private MultispectralImage? _loadedImage;

    protected override async Task OnInitializedAsync()
    {
        if (ProjectState.HasProject && !string.IsNullOrWhiteSpace(ProjectState.Configuration?.InputRasterPath))
        {
            _bandNames = ProjectState.Configuration.Bands?.Select(b => b.Name).ToList() ?? [];

            if (_bandNames.Count > 0)
            {
                _selectedBand = _bandNames[0];

                // Load raster info if not already available
                if (!ProjectState.HasRasterInfo)
                {
                    try
                    {
                        var info = await Task.Run(() => RasterService.GetInfo(ProjectState.Configuration.InputRasterPath));
                        ProjectState.RasterInfo = info;
                    }
                    catch { /* handled in UI */ }
                }

                await LoadBandData();
            }
        }
    }

    private async Task OnBandChanged()
    {
        if (_selectedBand is not null)
            await LoadBandData();
    }

    private async Task LoadBandData()
    {
        if (_selectedBand is null || ProjectState.Configuration?.InputRasterPath is null) return;

        _isLoading = true;
        StateHasChanged();

        try
        {
            // Load image if not cached
            if (_loadedImage is null)
            {
                _loadedImage = await Task.Run(() =>
                    RasterService.ReadImage(ProjectState.Configuration.InputRasterPath, _bandNames));
            }

            var band = _loadedImage.GetBand(_selectedBand);

            // Compute statistics
            var stats = await Task.Run(() => RasterService.ComputeBandStatistics(band));
            _stats = stats;

            // Build histogram display data (sample every 4th bin for chart readability)
            _histogramData = [];
            for (var i = 0; i < 256; i += 4)
            {
                long sum = 0;
                for (var j = i; j < Math.Min(i + 4, 256); j++)
                    sum += stats.Histogram[j];
                _histogramData.Add(new HistBin(i.ToString(), sum));
            }

            // Render preview
            var png = await Task.Run(() => RasterService.RenderBandPreview(band));
            _bandPreviewBase64 = Convert.ToBase64String(png);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Load Error",
                $"Failed to load band data: {ex.Message}", duration: 5000);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private record HistBin(string Bin, long Count);
}
