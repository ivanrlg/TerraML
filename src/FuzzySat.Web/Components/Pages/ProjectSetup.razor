    private void ResetConfiguration()
    {
        _projectName = "";
        _inputPath = "";
        _selectedPreset = "ASTER";
        _inputMode = InputMode.DirectPath;
        _rasterInfo = null;
        _rasterError = null;
        _importFolderPath = "";
        _importOutputPath = "";
        _importSourceError = null;
        _importDetectedFormat = null;
        _discoveredBands = [];
        _importSelectedBands = [];
        _availableResolutions = [];
        _importComplete = false;
        _bands = [new("VNIR1", 0, "Visible NIR 1"), new("VNIR2", 1, "Visible NIR 2"), new("SWIR1", 2, "Shortwave IR 1"), new("SWIR2", 3, "Shortwave IR 2")];
        _classes =
        [
            new("Urban", 1, "#EF4444"), new("Water", 2, "#3B82F6"), new("Forest", 3, "#10B981"),
            new("Agriculture", 4, "#F59E0B"), new("Bare Soil", 5, "#D97706"),
            new("Cloud", 6, "#E8ECF4"), new("Shadow", 7, "#6B7280")
        ];

        ProjectState.Reset();
        NotificationService.Notify(NotificationSeverity.Info, "Reset",
            "Configuration reset to defaults.", duration: 3000);
    }

    private void ApplyPreset(SensorPreset preset)
    {
        _selectedPreset = preset.Name;
        if (preset.Name == "ASTER")
        {
            _bands = [new("VNIR1", 0, "Visible NIR 1"), new("VNIR2", 1, "Visible NIR 2"), new("SWIR1", 2, "Shortwave IR 1"), new("SWIR2", 3, "Shortwave IR 2")];
        }
        else if (preset.Name == "Sentinel-2")
        {
            _bands =
            [
                new("B1", 0, "Coastal Aerosol"), new("B2", 1, "Blue"), new("B3", 2, "Green"), new("B4", 3, "Red"),
                new("B5", 4, "Red Edge 1"), new("B6", 5, "Red Edge 2"), new("B7", 6, "Red Edge 3"),
                new("B8", 7, "NIR"), new("B8A", 8, "NIR Narrow"), new("B9", 9, "Water Vapour"),
                new("B10", 10, "Cirrus"), new("B11", 11, "SWIR 1"), new("B12", 12, "SWIR 2")
            ];
        }
        else if (preset.Name == "Landsat 8")
        {
            _bands =
            [
                new("B1", 0, "Coastal/Aerosol"), new("B2", 1, "Blue"), new("B3", 2, "Green"), new("B4", 3, "Red"),
                new("B5", 4, "NIR"), new("B6", 5, "SWIR 1"), new("B7", 6, "SWIR 2"),
                new("B8", 7, "Panchromatic"), new("B9", 8, "Cirrus"), new("B10", 9, "TIR 1"), new("B11", 10, "TIR 2")
            ];
        }
        else if (preset.Name == "Custom")
        {
            _bands = [];
        }
    }

    // Fix: reassign list to trigger Radzen DataGrid change detection
    private void AddBand() => _bands = [.. _bands, new($"Band{_bands.Count + 1}", _bands.Count, "")];
    private void AddClass() => _classes = [.. _classes, new($"Class{_classes.Count + 1}", _classes.Count + 1, "#808080")];

    private enum InputMode { DirectPath, ImportSentinel2 }
    private record BandEntry(string Name, int Index, string Description);
    private record ClassEntry(string Name, int Code, string Color);
    private record SensorPreset(string Name, int Bands, string Resolution);
