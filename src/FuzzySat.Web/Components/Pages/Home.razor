@page "/"

<PageTitle>FuzzySat - Fuzzy Logic Satellite Image Classifier</PageTitle>

<div class="home-page fs-fade-in">
    @* Hero Section *@
    <div class="hero">
        <div class="hero-bg-pattern"></div>
        <div class="hero-content">
            <div class="hero-badge">
                <span class="material-icons" style="font-size: 0.85rem;">satellite_alt</span>
                Open Source Satellite Classifier
            </div>
            <h1 class="hero-title">
                <span class="fs-gradient-text">FuzzySat</span>
            </h1>
            <p class="hero-subtitle">
                Classify satellite imagery using fuzzy logic, hybrid ML, and pure machine learning.
                Open source, GDAL-powered, built for Sentinel-2.
            </p>
            <div class="hero-actions">
                <a href="project-setup" class="hero-cta">
                    <span class="material-icons">rocket_launch</span>
                    Create New Project
                </a>
                <a href="https://browser.dataspace.copernicus.eu/" target="_blank" rel="noopener noreferrer" class="hero-cta-secondary">
                    <span class="material-icons">satellite_alt</span>
                    Get Satellite Imagery
                </a>
            </div>
        </div>
    </div>

    @* Stats Bar *@
    <div class="stats-row">
        <div class="stat-card fs-scale-in" style="animation-delay: 0.15s;">
            <span class="stat-number" style="color: var(--fs-accent-emerald);">3</span>
            <span class="stat-desc">Classification Modes</span>
            <span class="stat-detail">Fuzzy, Hybrid, Pure ML</span>
        </div>
        <div class="stat-card fs-scale-in" style="animation-delay: 0.25s;">
            <span class="stat-number" style="color: var(--fs-accent-blue);">7</span>
            <span class="stat-desc">ML Classifiers</span>
            <span class="stat-detail">RF, SDCA, LightGBM, SVM, LR, MLP, KMeans</span>
        </div>
        <div class="stat-card fs-scale-in" style="animation-delay: 0.35s;">
            <span class="stat-number" style="color: var(--fs-accent-violet);">4</span>
            <span class="stat-desc">MF Types</span>
            <span class="stat-detail">Gaussian, Tri, Trap, Bell</span>
        </div>
        <div class="stat-card fs-scale-in" style="animation-delay: 0.45s;">
            <span class="stat-number" style="color: var(--fs-accent-cyan);">13</span>
            <span class="stat-desc">Spectral Bands</span>
            <span class="stat-detail">Sentinel-2 Copernicus</span>
        </div>
    </div>

    @* Workflow Steps *@
    <div class="workflow-section">
        <h2 class="section-heading">
            <span class="material-icons" style="color: var(--fs-accent-blue);">route</span>
            Classification Workflow
        </h2>
        <div class="workflow-grid">
            <a href="project-setup" class="workflow-card fs-scale-in" style="animation-delay: 0.2s;">
                <div class="wf-step-badge">1</div>
                <span class="material-icons wf-icon" style="color: var(--fs-accent-blue);">tune</span>
                <span class="wf-title">Project Setup</span>
                <span class="wf-desc">Import rasters, configure bands, define land cover classes</span>
            </a>
            <a href="training" class="workflow-card fs-scale-in" style="animation-delay: 0.3s;">
                <div class="wf-step-badge">2</div>
                <span class="material-icons wf-icon" style="color: var(--fs-accent-cyan);">model_training</span>
                <span class="wf-title">Explore & Train</span>
                <span class="wf-desc">Visualize bands, draw training areas, extract spectral statistics</span>
            </a>
            <a href="classification" class="workflow-card fs-scale-in" style="animation-delay: 0.4s;">
                <div class="wf-step-badge">3</div>
                <span class="material-icons wf-icon" style="color: var(--fs-accent-amber);">category</span>
                <span class="wf-title">Classification</span>
                <span class="wf-desc">Run fuzzy, hybrid, or pure ML classification</span>
            </a>
            <a href="validation" class="workflow-card fs-scale-in" style="animation-delay: 0.5s;">
                <div class="wf-step-badge">4</div>
                <span class="material-icons wf-icon" style="color: var(--fs-accent-violet);">assessment</span>
                <span class="wf-title">Validation</span>
                <span class="wf-desc">Confusion matrix, Kappa, per-class accuracy</span>
            </a>
            <a href="model-comparison" class="workflow-card fs-scale-in" style="animation-delay: 0.6s;">
                <div class="wf-step-badge">5</div>
                <span class="material-icons wf-icon" style="color: var(--fs-accent-emerald);">compare</span>
                <span class="wf-title">Compare Models</span>
                <span class="wf-desc">Cross-validate and compare all classification methods</span>
            </a>
        </div>
    </div>

    @* Feature Highlights *@
    <div class="features-section">
        <h2 class="section-heading">
            <span class="material-icons" style="color: var(--fs-accent-cyan);">auto_awesome</span>
            Key Capabilities
        </h2>
        <div class="features-grid">
            <div class="feature-card fs-scale-in" style="animation-delay: 0.3s;">
                <span class="material-icons feature-icon" style="color: var(--fs-accent-blue);">insights</span>
                <h3 class="feature-title">Fuzzy Inference Engine</h3>
                <p class="feature-desc">4 membership functions (Gaussian, Triangular, Trapezoidal, Bell) with configurable AND operators (Min, Product) and defuzzifiers. Pure fuzzy classification pixel-by-pixel.</p>
            </div>
            <div class="feature-card fs-scale-in" style="animation-delay: 0.4s;">
                <span class="material-icons feature-icon" style="color: var(--fs-accent-emerald);">psychology</span>
                <h3 class="feature-title">Hybrid & Pure ML</h3>
                <p class="feature-desc">7 ML classifiers (Random Forest, SDCA, LightGBM, SVM, Logistic Regression, MLP Neural Network, KMeans). Use fuzzy-enriched features or raw band values. Ensemble voting & stacking.</p>
            </div>
            <div class="feature-card fs-scale-in" style="animation-delay: 0.5s;">
                <span class="material-icons feature-icon" style="color: var(--fs-accent-cyan);">satellite_alt</span>
                <h3 class="feature-title">Sentinel-2 Ready</h3>
                <p class="feature-desc">Smart import wizard for Copernicus Sentinel-2 data. Auto-detect format, build VRT, 13 bands at 10-60m resolution. GDAL-powered raster I/O.</p>
            </div>
        </div>
    </div>

    @* About / Inspiration *@
    <div class="about-section">
        <div class="about-content">
            <span class="material-icons about-icon">school</span>
            <div>
                <p class="about-text">
                    <strong>About this project</strong> &mdash;
                    FuzzySat is inspired by an undergraduate thesis
                    (Universidad de Los Andes, Venezuela, 2008) where fuzzy logic was used to classify
                    Landsat satellite imagery using MATLAB. This open-source reimplementation in C#/.NET
                    extends the original concept with modern ML classifiers, Sentinel-2 support,
                    and a web-based interface.
                </p>
            </div>
        </div>
    </div>
</div>
